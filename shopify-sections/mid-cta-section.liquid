<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl-mid-cta {
    background: {{ section.settings.background_color }};
    padding: 32px 20px;
    text-align: center;
    border-top: 3px solid {{ section.settings.border_color }};
    border-bottom: 3px solid {{ section.settings.border_color }};
  }

  .cl-mid-cta .cl-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .cl-mid-cta-headline {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: {{ section.settings.headline_color }};
    margin-bottom: 6px;
  }

  .cl-mid-cta-sub {
    color: #777;
    margin-bottom: 20px;
    font-size: .95rem;
    font-family: 'Open Sans', sans-serif;
  }

  .cl-mid-cta-sub strong {
    color: {{ section.settings.price_color }};
  }

  /* ── Botón CTA ── */
  .cl-mid-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(180deg, #c97a46, #ad6639);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 900;
    text-decoration: none;
    padding: 22px 36px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: .5px;
    box-shadow: 0 8px 0 #7a4520, 0 12px 30px rgba(173,102,57,.4);
    transition: all .15s ease;
    max-width: 640px;
    width: 100%;
    margin: 10px auto;
    position: relative;
    overflow: hidden;
  }

  .cl-mid-cta-btn::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
    animation: cl-mid-shimmer 2.5s infinite;
  }

  @keyframes cl-mid-shimmer { 0% { left: -100%; } 100% { left: 200%; } }

  .cl-mid-cta-btn:hover {
    transform: translateY(3px);
    box-shadow: 0 5px 0 #7a4520, 0 8px 18px rgba(173,102,57,.3);
  }

  .cl-mid-cta-trust {
    margin-top: 14px;
    font-size: .8rem;
    color: #aaa;
    font-family: 'Open Sans', sans-serif;
  }

  @media (max-width: 768px) {
    .cl-mid-cta-btn { font-size: 1rem; padding: 18px 18px; }
  }
</style>

<div class="cl-mid-cta">
  <div class="cl-container">

    <p class="cl-mid-cta-headline">{{ section.settings.headline }}</p>

    <p class="cl-mid-cta-sub">
      {{ section.settings.subtitle_before_price }}
      <strong>{{ section.settings.price }}</strong>
      {{ section.settings.subtitle_after_price }}
    </p>

    <a href="{{ section.settings.cta_url }}" class="cl-mid-cta-btn">
      <i class="fa-solid {{ section.settings.cta_icon }}"></i>
      {{ section.settings.cta_text }}
    </a>

    {% if section.settings.trust_text != blank %}
      <p class="cl-mid-cta-trust">{{ section.settings.trust_text }}</p>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Mid CTA",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo de la sección",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color del borde superior e inferior",
      "default": "#fed3da"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Color del título",
      "default": "#3a2a1e"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Color del precio",
      "default": "#ad6639"
    },
    {
      "type": "header",
      "content": "Textos"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Título principal",
      "default": "¿Ya te convenciste?"
    },
    {
      "type": "text",
      "id": "subtitle_before_price",
      "label": "Texto antes del precio",
      "default": "La guía completa + 3 bonos VIP por un único pago de"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Precio destacado",
      "default": "$14.999"
    },
    {
      "type": "text",
      "id": "subtitle_after_price",
      "label": "Texto después del precio (vacío para ocultar)"
    },
    {
      "type": "header",
      "content": "Botón"
    },
    {
      "type": "text",
      "id": "cta_icon",
      "label": "Ícono del botón (Font Awesome)",
      "default": "fa-campground",
      "info": "Solo el nombre: fa-campground, fa-arrow-right, etc."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "QUIERO MI GUÍA AHORA"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Texto de confianza bajo el botón (vacío para ocultar)",
      "default": "🛡 Garantía 7 días sin preguntas · ⚡ Acceso instantáneo"
    }
  ],
  "presets": [
    {
      "name": "Mid CTA"
    }
  ]
}
{% endschema %}
