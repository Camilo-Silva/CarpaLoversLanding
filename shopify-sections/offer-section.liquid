{% comment %} ═══ OFFER STACK SECTION ═══ {% endcomment %}

<style>
  .cl-offer-section {
    background: {{ section.settings.bg_color }};
    color: var(--text, #3a2a1e);
    text-align: center;
  }
  .cl-offer-band {
    padding: 50px 20px;
  }
  .cl-offer-band--dark {
    background: {{ section.settings.price_band_bg }};
    color: var(--dark, #2a1a0e);
    padding: 50px 20px;
  }
  .cl-offer-divider-img {
    width: 100%;
    display: block;
  }
  .cl-offer-section .cl-section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(173,102,57,.12);
    color: #7a4520;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .78rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 50px;
    margin-bottom: 18px;
  }
  .cl-offer-section .cl-section-title {
    text-align: center;
    font-size: 2.1rem;
    margin-bottom: 8px;
    font-family: 'Montserrat', sans-serif;
    color: #2a1a0e;
  }
  .cl-offer-section .cl-section-subtitle {
    text-align: center;
    color: #555;
    margin-bottom: 16px;
    font-size: .97rem;
  }
  .cl-offer-intro {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    color: #2a1a0e;
    margin-top: 28px;
  }

  /* ── Offer box ── */
  .cl-offer-box {
    background: #fff;
    border: 2px solid rgba(173,102,57,.25);
    border-radius: 16px;
    padding: 40px;
  }

  /* ── Bonus rows ── */
  .cl-bonus-row {
    background: rgba(173,102,57,.07);
    border-radius: 10px;
    margin-bottom: 14px;
    text-align: left;
    border-left: 4px solid #ad6639;
    overflow: hidden;
    cursor: pointer;
  }
  .cl-bonus-row-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    user-select: none;
  }
  .cl-bonus-b-arr {
    font-size: .7rem;
    color: #ad6639;
    transition: transform .3s;
    margin-left: auto;
    flex-shrink: 0;
  }
  .cl-bonus-row.cl-open .cl-bonus-b-arr { transform: rotate(180deg); }
  .cl-bonus-row-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height .35s ease, padding .3s ease;
    padding: 0 20px;
    font-size: .88rem;
    color: #555;
  }
  .cl-bonus-row.cl-open .cl-bonus-row-body { max-height: 160px; padding: 0 20px 16px; }
  .cl-bonus-emoji {
    font-size: 1.9rem;
    flex-shrink: 0;
    color: #ad6639;
  }
  .cl-bonus-name {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 5px;
    color: #2a1a0e;
  }
  .cl-bonus-val {
    display: inline-block;
    background: rgba(173,102,57,.12);
    color: #7a4520;
    font-size: .72rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 10px;
    margin-bottom: 7px;
  }

  /* ── Value stack ── */
  .cl-value-stack {
    margin-top: 32px;
    padding: 36px;
    background: rgba(255,255,255,.7);
    border: 2px solid #e8dbd3;
    border-radius: 16px;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }
  .cl-real-value {
    text-decoration: line-through;
    color: #a07050;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .cl-big-price {
    font-family: 'Montserrat', sans-serif;
    font-size: 3.2rem;
    font-weight: 900;
    color: #ad6639;
    line-height: 1;
  }
  .cl-ars-price { font-size: 1.1rem; color: #777; margin-top: 6px; }

  /* ── CTA button (igual que en hero) ── */
  .cl-offer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #c97a46, #ad6639);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 1.15rem;
    letter-spacing: .04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 20px 42px;
    border-radius: 50px;
    box-shadow: 0 8px 0 #7a4520;
    position: relative;
    overflow: hidden;
    transition: transform .15s, box-shadow .15s;
    margin-top: 28px;
  }
  .cl-offer-cta-btn::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: rgba(255,255,255,.18);
    transform: skewX(-20deg);
    animation: cl-shimmer 2.8s infinite;
  }
  @keyframes cl-shimmer { 0%{left:-100%} 100%{left:200%} }
  .cl-offer-cta-btn:hover {
    transform: translateY(3px);
    box-shadow: 0 5px 0 #7a4520;
  }
  .cl-offer-cta-sub {
    font-size: .78rem;
    color: #999;
    margin-top: 8px;
  }

  @media (max-width: 600px) {
    .cl-offer-box { padding: 24px 16px; }
    .cl-offer-cta-btn { font-size: 1rem; padding: 18px 28px; }
    .cl-big-price { font-size: 2.6rem; }
  }
</style>

<section class="cl-offer-section">

  {%- comment -%} ── BANDA 1: encabezado ── {%- endcomment -%}
  <div class="cl-offer-band">
    <div class="container">
      <div class="cl-section-label">
        <i class="fa-solid fa-gift"></i> {{ section.settings.label_text }}
      </div>
      <h2 class="cl-section-title">{{ section.settings.headline }}</h2>
      <p class="cl-section-subtitle">
        {{ section.settings.subtitle_before }}
        <strong style="color:#ad6639;">{{ section.settings.subtitle_highlight }}</strong>
        {{ section.settings.subtitle_after }}
      </p>
      <p class="cl-offer-intro">
        <i class="fa-solid fa-box-open"></i> {{ section.settings.intro_text }}
      </p>
    </div>
  </div>

  {%- comment -%} ── IMAGEN DIVISORA 1 ── {%- endcomment -%}
  {%- if section.settings.divider_img_1 != blank -%}
    <img src="{{ section.settings.divider_img_1 | img_url: 'master' }}"
         alt="{{ section.settings.divider_img_1_alt }}"
         class="cl-offer-divider-img">
  {%- endif -%}

  {%- comment -%} ── BANDA 2: bonus rows ── {%- endcomment -%}
  <div class="cl-offer-band">
    <div class="container">
      <div class="cl-offer-box">

        {%- for block in section.blocks -%}
          {%- if block.type == 'bonus_item' -%}
            <div class="cl-bonus-row" {{ block.shopify_attributes }}>
              <div class="cl-bonus-row-header">
                <div class="cl-bonus-emoji">
                  <i class="fa-solid fa-{{ block.settings.icon }}"></i>
                </div>
                <div>
                  <div class="cl-bonus-name">{{ block.settings.name }}</div>
                  <div class="cl-bonus-val">{{ block.settings.value_badge }}</div>
                </div>
                <span class="cl-bonus-b-arr">▼</span>
              </div>
              <div class="cl-bonus-row-body">{{ block.settings.description }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  </div>

  {%- comment -%} ── IMAGEN DIVISORA 2 ── {%- endcomment -%}
  {%- if section.settings.divider_img_2 != blank -%}
    <img src="{{ section.settings.divider_img_2 | img_url: 'master' }}"
         alt="{{ section.settings.divider_img_2_alt }}"
         class="cl-offer-divider-img">
  {%- endif -%}

  {%- comment -%} ── BANDA 3: precio + CTA ── {%- endcomment -%}
  <div class="cl-offer-band--dark">
    <div class="container">
      <div class="cl-value-stack">
        <div class="cl-real-value">{{ section.settings.real_value_text }}</div>
        <div class="cl-big-price">{{ section.settings.price_display }}</div>
        <div class="cl-ars-price">{{ section.settings.price_currency_label }}</div>
      </div>
      <div style="text-align:center;">
        <a href="{{ section.settings.cta_url }}" class="cl-offer-cta-btn">
          <i class="fa-solid fa-arrow-right"></i> {{ section.settings.cta_text }}
        </a>
        <p class="cl-offer-cta-sub">
          <i class="fa-solid fa-bolt"></i> {{ section.settings.trust_text }}
        </p>
      </div>
    </div>
  </div>

</section>

<script>
(function () {
  document.querySelectorAll('.cl-bonus-row').forEach(function (row) {
    row.addEventListener('click', function () {
      var isOpen = row.classList.contains('cl-open');
      document.querySelectorAll('.cl-bonus-row').forEach(function (r) { r.classList.remove('cl-open'); });
      if (!isOpen) { row.classList.add('cl-open'); }
    });
  });
})();
</script>

