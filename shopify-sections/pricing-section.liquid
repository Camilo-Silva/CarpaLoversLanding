      "id": "cta_text",
      "label": "Texto del botón",
      "default": "¡OFERTA TERMINA HOY!"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "URL del botón (checkout)",
      "default": "https://sinmiedoacampar.com/cart/43132623224966:1"
    },
    {
      "type": "header",
      "content": "Countdown"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Mostrar countdown",
      "default": true
    },
    {
      "type": "range",
      "id": "countdown_hours",
      "label": "Duración del countdown (horas)",
      "min": 1,
      "max": 24,
      "step": 1,
      "default": 1
    },
    {
      "type": "text",
      "id": "countdown_header",
      "label": "Texto cabecera countdown",
      "default": "Oferta Limitada: ¡Últimas horas para aprovechar el 50% OFF!"
    },
    {
      "type": "text",
      "id": "countdown_footer",
