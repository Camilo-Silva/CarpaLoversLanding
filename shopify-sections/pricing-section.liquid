      "label": "Color botón y texto urgente",
      "default": "#ad6639"
    },
    {
      "type": "color",
      "id": "stars_color",
      "label": "Color estrellas",
      "default": "#f5a623"
    },
    {
      "type": "color",
      "id": "savings_color_from",
      "label": "Gradiente badge ahorro (inicio)",
      "default": "#00b140"
    },
    {
      "type": "color",
      "id": "savings_color_to",
      "label": "Gradiente badge ahorro (fin)",
      "default": "#007d2e"
    },
    {
      "type": "header",
