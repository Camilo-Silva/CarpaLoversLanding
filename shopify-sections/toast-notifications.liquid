{% comment %} ═══ PURCHASE TOAST NOTIFICATIONS ═══ {% endcomment %}

<style>
  .cl-toast-container {
    position: fixed;
    top: 60px; right: 14px;
    z-index: 10000;
    display: flex;
    flex-direction: column;
    gap: 7px;
    pointer-events: none;
  }
  .cl-toast {
    background: #fff;
    border-left: 3px solid #3d9970;
    border-radius: 8px;
    padding: 8px 11px;
    box-shadow: 0 4px 16px rgba(0,0,0,.14);
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: 240px;
    font-size: .75rem;
    animation: cl-toastIn .3s ease forwards;
    font-family: 'Open Sans', sans-serif;
  }
  .cl-toast.cl-out { animation: cl-toastOut .3s ease forwards; }
  .cl-t-av {
    width: 30px; height: 30px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .78rem;
    color: #fff;
    flex-shrink: 0;
  }
  .cl-toast-body strong { display: block; color: #111; font-size: .78rem; line-height: 1.2; }
  .cl-toast-body span   { color: #666; font-size: .72rem; }
  .cl-toast-check { color: #3d9970; font-size: .95rem; margin-left: auto; flex-shrink: 0; }
  @keyframes cl-toastIn  { from{opacity:0;transform:translateX(28px)} to{opacity:1;transform:translateX(0)} }
  @keyframes cl-toastOut { from{opacity:1;transform:translateX(0)} to{opacity:0;transform:translateX(28px)} }
</style>

<div class="cl-toast-container" id="cl-toastContainer"></div>

<script>
(function () {
  var buyers = [
    { name: 'Valentina M.',  city: 'Buenos Aires', ini: 'VM',  bg: 'linear-gradient(135deg,#e63946,#c1121f)' },
    { name: 'Lucas R.',      city: 'Córdoba',       ini: 'LR',  bg: 'linear-gradient(135deg,#3d9970,#2d6a4f)' },
    { name: 'Sofía P.',      city: 'Rosario',       ini: 'SP',  bg: 'linear-gradient(135deg,#7b2d8b,#4a1060)' },
    { name: 'Matías G.',     city: 'Mendoza',       ini: 'MG',  bg: 'linear-gradient(135deg,#e07b00,#c45c00)' },
    { name: 'Camila F.',     city: 'Mar del Plata', ini: 'CF',  bg: 'linear-gradient(135deg,#007bc1,#005a8e)' },
    { name: 'Nicolás T.',    city: 'Salta',         ini: 'NT',  bg: 'linear-gradient(135deg,#1a1f71,#3546c5)' },
    { name: 'Florencia B.',  city: 'Paraguay',      ini: 'FB',  bg: 'linear-gradient(135deg,#e63946,#c1121f)' },
    { name: 'Diego A.',      city: 'Tucumán',       ini: 'DA',  bg: 'linear-gradient(135deg,#3d9970,#2d6a4f)' },
    { name: 'Martina C.',    city: 'Santa Fe',      ini: 'MC',  bg: 'linear-gradient(135deg,#7b2d8b,#4a1060)' },
    { name: 'Agustín L.',    city: 'Bahía Blanca',  ini: 'AL',  bg: 'linear-gradient(135deg,#e07b00,#c45c00)' },
    { name: 'Carolina V.',   city: 'San Juan',      ini: 'CV',  bg: 'linear-gradient(135deg,#007bc1,#005a8e)' },
    { name: 'Facundo H.',    city: 'Neuquén',       ini: 'FH',  bg: 'linear-gradient(135deg,#1a1f71,#3546c5)' },
    { name: 'Julieta S.',    city: 'Paraná',        ini: 'JS',  bg: 'linear-gradient(135deg,#e63946,#c1121f)' },
    { name: 'Emiliano R.',   city: 'Posadas',       ini: 'ER',  bg: 'linear-gradient(135deg,#3d9970,#2d6a4f)' },
    { name: 'Paula M.',      city: 'Tandil',        ini: 'PM',  bg: 'linear-gradient(135deg,#7b2d8b,#4a1060)' },
    { name: 'Rodrigo N.',    city: 'San Luis',      ini: 'RN',  bg: 'linear-gradient(135deg,#e07b00,#c45c00)' },
    { name: 'Micaela G.',    city: 'Chile',         ini: 'MG2', bg: 'linear-gradient(135deg,#007bc1,#005a8e)' },
    { name: 'Gonzalo P.',    city: 'Formosa',       ini: 'GP',  bg: 'linear-gradient(135deg,#1a1f71,#3546c5)' },
    { name: 'Natalia Q.',    city: 'La Rioja',      ini: 'NQ',  bg: 'linear-gradient(135deg,#e63946,#c1121f)' },
    { name: 'Sebastián K.',  city: 'Uruguay',       ini: 'SK',  bg: 'linear-gradient(135deg,#3d9970,#2d6a4f)' }
  ];
  var times     = ['hace 1 min', 'hace 2 min', 'hace 3 min', 'hace 5 min', 'recién ahora', 'hace 8 min'];
  var container = document.getElementById('cl-toastContainer');
  var idx       = Math.floor(Math.random() * buyers.length);

  function showToast() {
    var b   = buyers[idx % buyers.length]; idx++;
    var t   = times[Math.floor(Math.random() * times.length)];
    var div = document.createElement('div');
    div.className = 'cl-toast';
    div.innerHTML =
      '<div class="cl-t-av" style="background:' + b.bg + '">' + b.ini + '</div>' +
      '<div class="cl-toast-body">' +
        '<strong>' + b.name + ' de ' + b.city + '</strong>' +
        '<span>acaba de comprar la guía — ' + t + '</span>' +
      '</div>' +
      '<div class="cl-toast-check">✔</div>';
    container.appendChild(div);
    setTimeout(function () {
      div.classList.add('cl-out');
      setTimeout(function () { div.remove(); }, 380);
    }, 4800);
  }

  setTimeout(function () {
    showToast();
    setInterval(showToast, 25000 + Math.random() * 15000);
  }, 30000);
})();
</script>

