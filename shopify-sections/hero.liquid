<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl-hero {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    text-align: center;
    padding: 75px 20px 65px;
  }

  .cl-hero .cl-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .cl-pre-headline {
    display: inline-block;
    background: rgba(173,102,57,.12);
    border: 1px solid {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
    font-family: 'Montserrat', sans-serif;
    font-size: .82rem;
    font-weight: 700;
    padding: 6px 18px;
    border-radius: 20px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .cl-hero h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.8rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 20px;
    color: {{ section.settings.text_color }};
  }

  .cl-hero h1 .cl-red {
    color: {{ section.settings.subtitle_color }};
  }

  .cl-hero-sub {
    font-family: 'Open Sans', sans-serif;
    font-size: 1.15rem;
    color: #5a3e2e;
    max-width: 680px;
    margin: 0 auto 8px;
    line-height: 1.7;
  }

  .cl-social-proof {
    font-size: .9rem;
    color: #7a5a47;
    margin-bottom: 38px;
    font-family: 'Open Sans', sans-serif;
  }

  .cl-social-proof strong {
    color: {{ section.settings.accent_color }};
    font-weight: 700;
  }

  .cl-cta-wrap { text-align: center; }

  .cl-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(180deg, #c97a46, #ad6639);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 900;
    text-decoration: none;
    padding: 22px 36px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: .5px;
    box-shadow: 0 8px 0 #7a4520, 0 12px 30px rgba(173,102,57,.4);
    transition: all .15s ease;
    max-width: 640px;
    width: 100%;
    margin: 10px auto;
    position: relative;
    overflow: hidden;
  }

  .cl-cta-btn::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
    animation: clShimmer 2.5s infinite;
  }

  @keyframes clShimmer { 0%{left:-100%} 100%{left:200%} }

  .cl-cta-btn:hover {
    transform: translateY(3px);
    box-shadow: 0 5px 0 #7a4520, 0 8px 18px rgba(173,102,57,.3);
  }

  .cl-cta-sub {
    font-size: .78rem;
    color: #999;
    margin-top: 8px;
    font-family: 'Open Sans', sans-serif;
  }

  @media (max-width: 768px) {
    .cl-hero h1 { font-size: 2rem; }
    .cl-cta-btn { font-size: 1rem; padding: 18px 18px; }
  }
</style>

<div class="cl-hero">
  <div class="cl-container">

    {% if section.settings.pre_headline != blank %}
      <p class="cl-pre-headline">
        <i class="fa-solid {{ section.settings.pre_headline_icon }}"></i>
        {{ section.settings.pre_headline }}
      </p>
    {% endif %}

    <h1>
      {{ section.settings.headline }}
      {% if section.settings.headline_sub != blank %}
        <br><span class="cl-red">{{ section.settings.headline_sub }}</span>
      {% endif %}
    </h1>

    {% if section.settings.subheadline != blank %}
      <p class="cl-hero-sub">{{ section.settings.subheadline }}</p>
    {% endif %}

    {% if section.settings.social_proof != blank %}
      <p class="cl-social-proof">
        {{ section.settings.social_proof | replace: section.settings.social_proof_highlight, '<strong>' | append: '</strong>' }}
      </p>
    {% endif %}

    <div class="cl-cta-wrap">
      <a href="{{ section.settings.cta_url }}" class="cl-cta-btn">
        <i class="fa-solid {{ section.settings.cta_icon }}"></i>
        {{ section.settings.cta_text }}
      </a>
      {% if section.settings.cta_sub != blank %}
        <p class="cl-cta-sub">{{ section.settings.cta_sub }}</p>
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Hero Principal",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto principal",
      "default": "#2a1a0e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento (pre-headline e íconos)",
      "default": "#ad6639"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color del subtítulo destacado",
      "default": "#c0392b"
    },
    {
      "type": "header",
      "content": "Textos"
    },
    {
      "type": "text",
      "id": "pre_headline_icon",
      "label": "Ícono pre-headline (Font Awesome)",
      "default": "fa-campground",
      "info": "Solo el nombre sin 'fa-solid', ej: fa-campground"
    },
    {
      "type": "text",
      "id": "pre_headline",
      "label": "Texto pre-headline (etiqueta superior)",
      "default": "Para todos los que quieren acampar pero no saben por dónde empezar"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline principal (línea 1)",
      "default": "La guía rápida para tu primera aventura en camping"
    },
    {
      "type": "text",
      "id": "headline_sub",
      "label": "Headline destacado (línea 2, en rojo)",
      "default": "(sin errores de principiante ni gastar de más)"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Aprendé en 2 horas todo lo que necesitás para acampar por primera vez con seguridad, incluso si nunca armaste una carpa."
    },
    {
      "type": "text",
      "id": "social_proof",
      "label": "Texto de prueba social",
      "default": "Ya la descargaron +2.000 campistas en toda América Latina ★★★★★"
    },
    {
      "type": "header",
      "content": "Botón CTA"
    },
    {
      "type": "text",
      "id": "cta_icon",
      "label": "Ícono del botón (Font Awesome)",
      "default": "fa-arrow-right"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "¡SÍ! QUIERO MI GUÍA + BONOS VIP POR SOLO $14.999"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "URL del botón (checkout)",
      "default": "https://sinmiedoacampar.com/cart/43132623224966:1"
    },
    {
      "type": "text",
      "id": "cta_sub",
      "label": "Texto debajo del botón",
      "default": "🔒 Compra segura · ⚡ Acceso instantáneo · 🛡️ Garantía 7 días sin preguntas"
    }
  ],
  "presets": [
    {
      "name": "Hero Principal"
    }
  ]
}
{% endschema %}
