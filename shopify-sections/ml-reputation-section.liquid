<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl-ml-rep-section {
    background: {{ section.settings.background_color }};
    padding: 40px 20px;
    text-align: center;
  }

  .cl-ml-rep-section .cl-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .cl-ml-rep-img {
    display: block;
    max-width: 380px;
    width: 100%;
    margin: 0 auto 16px;
    border-radius: 12px;
    box-shadow: 0 3px 14px rgba(0,0,0,.1);
  }

  .cl-ml-live {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff3e0;
    border: 1px solid #ff9800;
    color: #e65100;
    padding: 7px 16px;
    border-radius: 20px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .82rem;
  }

  .cl-ml-live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #f44336;
    animation: cl-blink 1s infinite;
    flex-shrink: 0;
  }

  @keyframes cl-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<div class="cl-ml-rep-section">
  <div class="cl-container">

    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | img_url: 'master' }}"
        alt="{{ section.settings.image_alt }}"
        class="cl-ml-rep-img"
      >
    {% endif %}

    <div class="cl-ml-live">
      <div class="cl-ml-live-dot"></div>
      <span id="cl-live-count">7</span>&nbsp;{{ section.settings.live_text }}
    </div>

  </div>
</div>

<script>
(function () {
  var pool = [4, 5, 6, 7, 8, 10, 11, 17];
  function pick() { return pool[Math.floor(Math.random() * pool.length)]; }

  var el  = document.getElementById('cl-live-count');
  if (!el) return;

  el.textContent = pick();
  setInterval(function () { el.textContent = pick(); }, 4500);
})();
</script>

{% schema %}
{
  "name": "Reputación ML",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo de la sección",
      "default": "#d1ccec"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de reputación (ej: badge MercadoLíder)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texto alternativo de la imagen",
      "default": "MercadoLíder Platinum - Reputación del vendedor"
    },
    {
      "type": "text",
      "id": "live_text",
      "label": "Texto del contador de visitantes",
      "default": "personas mirando esto ahora"
    }
  ],
  "presets": [
    {
      "name": "Reputación ML"
    }
  ]
}
{% endschema %}
