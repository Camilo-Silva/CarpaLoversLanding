<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl-product-card-section {
    background: {{ section.settings.background_color }};
    padding: 50px 20px;
  }

  .cl-product-card-section .cl-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .cl-product-card {
    background: #fff;
    border: 1px solid #dde0e7;
    border-radius: 14px;
    max-width: 420px;
    margin: 0 auto;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,.09);
  }

  .cl-product-card-img {
    width: 100%;
    display: block;
    background: #eef3fb;
  }

  .cl-product-card-body {
    padding: 22px 24px 28px;
  }

  .cl-product-card-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 1.35rem;
    color: #111;
    margin-bottom: 14px;
    line-height: 1.25;
  }

  .cl-product-price-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .cl-product-price-old {
    font-size: .95rem;
    color: #999;
    text-decoration: line-through;
    font-family: 'Open Sans', sans-serif;
  }

  .cl-product-price-new {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    color: #111;
  }

  .cl-product-off-badge {
    background: {{ section.settings.badge_color }};
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .75rem;
    padding: 4px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: .5px;
  }

  .cl-product-cta {
    display: block;
    background: linear-gradient(180deg, {{ section.settings.cta_color_from }}, {{ section.settings.cta_color_to }});
    color: #fff;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity .15s;
  }
  .cl-product-cta:hover { opacity: .88; }

  /* ── Mobile full-bleed ── */
  @media (max-width: 768px) {
    .cl-product-card-section            { padding: 0 0 32px; }
    .cl-product-card-section .cl-container { padding: 0; }
    .cl-product-card                    { max-width: 100%; border-radius: 0; box-shadow: none; border-left: none; border-right: none; }
    .cl-product-card-img                { border-radius: 0; }
    .cl-product-card-body               { padding: 20px 20px 24px; }
  }
</style>

<div class="cl-product-card-section">
  <div class="cl-container">
    <div class="cl-product-card">

      {% if section.settings.product_image != blank %}
        <img
          src="{{ section.settings.product_image | img_url: 'master' }}"
          alt="{{ section.settings.image_alt }}"
          class="cl-product-card-img"
        >
      {% endif %}

      <div class="cl-product-card-body">

        <div class="cl-product-card-title">{{ section.settings.product_title }}</div>

        <div class="cl-product-price-row">
          {% if section.settings.price_old != blank %}
            <span class="cl-product-price-old">{{ section.settings.price_old }}</span>
          {% endif %}
          <span class="cl-product-price-new">{{ section.settings.price_current }}</span>
          {% if section.settings.badge_text != blank %}
            <span class="cl-product-off-badge">{{ section.settings.badge_text }}</span>
          {% endif %}
        </div>

        <a href="{{ section.settings.cta_url }}" class="cl-product-cta">
          {{ section.settings.cta_text }}
        </a>

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Card",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto (portada del ebook)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texto alternativo de la imagen",
      "default": "De Cero a Campista — Guía Rápida para Campistas"
    },
    {
      "type": "header",
      "content": "Textos"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Título del producto",
      "default": "De Cero a Campista + 3 bonos VIP"
    },
    {
      "type": "text",
      "id": "price_current",
      "label": "Precio actual",
      "default": "$14.999"
    },
    {
      "type": "text",
      "id": "price_old",
      "label": "Precio tachado (dejar vacío para ocultar)",
      "default": "$30.000"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texto del badge (dejar vacío para ocultar)",
      "default": "OFERTA -50% OFF"
    },
    {
      "type": "header",
      "content": "Botón CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "COMPRAR AHORA"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "URL del botón (checkout)",
      "default": "https://sinmiedoacampar.com/cart/43132623224966:1"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo de la sección",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Color del badge",
      "default": "#ad6639"
    },
    {
      "type": "color",
      "id": "cta_color_from",
      "label": "Botón CTA — color gradiente inicio",
      "default": "#1e9e4f"
    },
    {
      "type": "color",
      "id": "cta_color_to",
      "label": "Botón CTA — color gradiente fin",
      "default": "#178040"
    }
  ],
  "presets": [
    {
      "name": "Product Card"
    }
  ]
}
{% endschema %}
