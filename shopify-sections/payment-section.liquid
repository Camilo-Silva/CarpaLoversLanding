{% comment %} ═══ PAYMENT / MÉTODOS DE PAGO SECTION ═══ {% endcomment %}

<style>
  .cl-payment-section {
    background: #fff;
    padding: 44px 20px;
    text-align: center;
    border-top: 1px solid #e8dbd3;
  }
  .cl-payment-section h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: .85rem;
    font-weight: 600;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 22px;
  }
  .cl-pay-img {
    display: block;
    max-width: 420px;
    width: 100%;
    margin: 0 auto 18px;
  }
  .cl-ssl-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #e8f5e9;
    color: #2e7d32;
    font-size: .78rem;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 20px;
    margin-top: 14px;
    font-family: 'Montserrat', sans-serif;
  }
</style>

<section class="cl-payment-section">
  <div class="container">
    <h3>{{ section.settings.heading }}</h3>

    {%- if section.settings.payment_image != blank -%}
      <img
        src="{{ section.settings.payment_image | img_url: 'master' }}"
        alt="{{ section.settings.payment_image_alt }}"
        class="cl-pay-img">
    {%- endif -%}

    <div>
      <span class="cl-ssl-badge">
        <i class="fa-solid fa-lock"></i> {{ section.settings.ssl_text }}
      </span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Métodos de Pago",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Métodos de pago"
    },
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Imagen métodos de pago"
    },
    {
      "type": "text",
      "id": "payment_image_alt",
      "label": "Alt de la imagen",
      "default": "Métodos de pago: Mercado Pago, Visa, Mastercard"
    },
    {
      "type": "text",
      "id": "ssl_text",
      "label": "Texto badge SSL",
      "default": "Sitio protegido con SSL — Tus datos nunca se comparten con terceros"
    }
  ],
  "presets": [
    {
      "name": "Métodos de Pago"
    }
  ]
}
{% endschema %}
