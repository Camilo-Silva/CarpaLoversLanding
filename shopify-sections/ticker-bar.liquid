<!-- Font Awesome (solo si tu tema de Shopify no lo carga ya) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  /* Contenedor edge-to-edge */
  .cl-ticker-bar {
    background-color: {{ section.settings.background_color }};
    border-top: 2px solid {{ section.settings.accent_color }};
    border-bottom: 2px solid {{ section.settings.accent_color }};
    overflow: hidden;
    display: block;
    padding: 10px 0;

    /* Forzar 100% del ancho de la ventana */
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    z-index: 10;
  }

  .cl-ticker-track {
    display: flex;
    width: max-content;
    animation: clTickerScroll {{ section.settings.speed }}s linear infinite;
  }

  .cl-ticker-track:hover {
    animation-play-state: paused;
  }

  .cl-ticker-group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    width: max-content;
  }

  .cl-ticker-item {
    font-size: 13px;
    font-weight: 800;
    font-style: normal;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    padding: 0 48px;
    display: flex;
    align-items: center;
    gap: 9px;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .cl-ticker-icon {
    font-size: 15px;
    line-height: 1;
    color: {{ section.settings.accent_color }};
  }

  @keyframes clTickerScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media screen and (max-width: 768px) {
    .cl-ticker-item {
      font-size: 11px;
      padding: 0 24px;
    }
  }
</style>

<div class="cl-ticker-bar" aria-label="Información de compra" role="marquee">
  <div class="cl-ticker-track">

    <!-- Grupo original -->
    <div class="cl-ticker-group">
      {% for block in section.blocks %}
        <div class="cl-ticker-item" {{ block.shopify_attributes }}>
          <i class="cl-ticker-icon fa-solid {{ block.settings.icon }}"></i> {{ block.settings.text }}
        </div>
      {% endfor %}
    </div>

    <!-- Duplicado para loop seamless -->
    <div class="cl-ticker-group" aria-hidden="true">
      {% for block in section.blocks %}
        <div class="cl-ticker-item">
          <i class="cl-ticker-icon fa-solid {{ block.settings.icon }}"></i> {{ block.settings.text }}
        </div>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Ticker Bar",
  "tag": "div",
  "class": "cl-ticker-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#2a1a0e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de iconos y bordes",
      "default": "#ad6639"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad (segundos por ciclo)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ítem del ticker",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "50% OFF por Tiempo Limitado"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono Font Awesome (ej: fa-bolt)",
          "default": "fa-bolt",
          "info": "Nombres en fontawesome.com/icons — usar solo el nombre sin 'fa-solid'"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ticker Bar",
      "blocks": [
        { "type": "item", "settings": { "text": "Pago 100% Seguro con Mercado Pago", "icon": "fa-shield-halved" } },
        { "type": "item", "settings": { "text": "50% OFF por Tiempo Limitado", "icon": "fa-bolt" } },
        { "type": "item", "settings": { "text": "Acceso Inmediato por Mail", "icon": "fa-envelope" } },
        { "type": "item", "settings": { "text": "Comprá desde toda Latam en tu moneda local", "icon": "fa-globe" } },
        { "type": "item", "settings": { "text": "Aceptamos tarjetas de todo el mundo", "icon": "fa-lock" } }
      ]
    }
  ]
}
{% endschema %}
