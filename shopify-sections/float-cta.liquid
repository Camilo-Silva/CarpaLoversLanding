{% comment %} ═══ FLOATING CTA BUTTON ═══ {% endcomment %}

<style>
  @keyframes cl-floatBounce {
    0%,100% { transform:translateX(-50%) translateY(0) scale(1); box-shadow:0 6px 24px rgba(0,0,0,0.35); }
    40%     { transform:translateX(-50%) translateY(-6px) scale(1.06); box-shadow:0 14px 32px rgba(0,0,0,0.3); }
    60%     { transform:translateX(-50%) translateY(-3px) scale(1.03); }
  }
  @keyframes cl-floatBounce-right {
    0%,100% { transform:translateY(0) scale(1); box-shadow:0 6px 24px rgba(0,0,0,0.35); }
    40%     { transform:translateY(-6px) scale(1.06); box-shadow:0 14px 32px rgba(0,0,0,0.3); }
    60%     { transform:translateY(-3px) scale(1.03); }
  }

  .cl-float-cta {
    display: flex;
    position: fixed;
    bottom: 20px;
    right: 28px;
    left: auto;
    transform: none;
    z-index: 9999;
    background: linear-gradient(135deg, {{ section.settings.bg_from }}, {{ section.settings.bg_to }});
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 50px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.35);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: .5px;
    align-items: center;
    gap: 10px;
    animation: cl-floatBounce-right 2.2s ease-in-out infinite;
  }
  .cl-float-cta:hover {
    animation: none;
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 10px 28px rgba(0,0,0,0.4);
  }

  @media (max-width: 768px) {
    .cl-float-cta {
      right: auto;
      left: 50%;
      transform: translateX(-50%);
      animation: cl-floatBounce 2.2s ease-in-out infinite;
    }
    .cl-float-cta:hover {
      animation: none;
      transform: translateX(-50%) translateY(-2px) scale(1.04);
    }
  }
</style>

<a href="{{ section.settings.cta_url }}" class="cl-float-cta">
  <i class="fa-solid fa-{{ section.settings.cta_icon }}"></i>
  {{ section.settings.cta_text }}
</a>

{% schema %}
{
  "name": "Botón Flotante",
  "settings": [
    {
      "type": "text",
      "id": "cta_icon",
      "label": "Ícono Font Awesome (sin fa-)",
      "default": "fire"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "DESCARGAR AHORA"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    },
    {
      "type": "color",
      "id": "bg_from",
      "label": "Color gradiente inicio",
      "default": "#1e9e4f"
    },
    {
      "type": "color",
      "id": "bg_to",
      "label": "Color gradiente fin",
      "default": "#27ae60"
    }
  ],
  "presets": [
    {
      "name": "Botón Flotante",
      "settings": {
        "cta_icon": "fire",
        "cta_text": "DESCARGAR AHORA"
      }
    }
  ]
}
{% endschema %}
