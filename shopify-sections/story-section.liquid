<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl-story-section {
    padding: 70px 20px;
    background: {{ section.settings.background_color }};
  }

  .cl-story-section .cl-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Label ── */
  .cl-story-label {
    display: inline-block;
    background: rgba(173,102,57,.12);
    color: {{ section.settings.accent_color }};
    font-family: 'Montserrat', sans-serif;
    font-size: .75rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  /* ── Headline ── */
  .cl-story-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.1rem;
    font-weight: 900;
    margin-bottom: 28px;
    color: {{ section.settings.headline_color }};
    line-height: 1.2;
  }

  /* ── Cuerpo ── */
  .cl-story-content {
    font-size: 1.05rem;
    border-left: 4px solid {{ section.settings.accent_color }};
    padding-left: 22px;
    font-family: 'Open Sans', sans-serif;
  }
  .cl-story-content p {
    margin-bottom: 18px;
    color: #444;
  }

  /* ── Highlight box ── */
  .cl-story-highlight {
    background: linear-gradient(135deg, #f5ede4, #eeddd0);
    border: 1px solid #d4a07a;
    border-radius: 10px;
    padding: 18px 24px;
    margin-top: 24px;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: {{ section.settings.headline_color }};
  }

  @media (max-width: 768px) {
    .cl-story-section { padding: 50px 20px; }
    .cl-story-section h2 { font-size: 1.6rem; }
  }
</style>

<div class="cl-story-section">
  <div class="cl-container">

    {% if section.settings.label != blank %}
      <div class="cl-story-label">
        <i class="fa-solid {{ section.settings.label_icon }}"></i> {{ section.settings.label }}
      </div>
    {% endif %}

    <h2>{{ section.settings.headline }}</h2>

    <div class="cl-story-content">
      {% for block in section.blocks %}
        {% if block.type == 'paragraph' %}
          <p {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.highlight_text != blank %}
      <div class="cl-story-highlight">
        <i class="fa-solid {{ section.settings.highlight_icon }}"></i> {{ section.settings.highlight_text }}
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Historia / Story",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo de la sección",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento (label y borde izquierdo)",
      "default": "#ad6639"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Color del título",
      "default": "#2a1a0e"
    },
    {
      "type": "header",
      "content": "Etiqueta superior"
    },
    {
      "type": "text",
      "id": "label_icon",
      "label": "Ícono (Font Awesome)",
      "default": "fa-book-open",
      "info": "Solo el nombre, ej: fa-book-open, fa-campground"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Texto de la etiqueta (dejar vacío para ocultar)",
      "default": "La historia detrás de esta guía"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Título principal",
      "default": "\"Durante años pensé que acampar no era para mí.\""
    },
    {
      "type": "header",
      "content": "Caja destacada"
    },
    {
      "type": "text",
      "id": "highlight_icon",
      "label": "Ícono de la caja destacada (Font Awesome)",
      "default": "fa-lightbulb"
    },
    {
      "type": "textarea",
      "id": "highlight_text",
      "label": "Texto de la caja destacada (dejar vacío para ocultar)",
      "default": "No es teoría — es lo que funciona de verdad en el campo, probado en cada salida."
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Párrafo",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Texto del párrafo",
          "default": "<p>Escribí tu historia aquí.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Historia / Story",
      "blocks": [
        {
          "type": "paragraph",
          "settings": {
            "text": "<p><strong>Hasta que me animé.</strong></p>"
          }
        },
        {
          "type": "paragraph",
          "settings": {
            "text": "<p>Después de tormentas, carpas mal armadas y muchos errores de principiante, descubrí algo:</p>"
          }
        },
        {
          "type": "paragraph",
          "settings": {
            "text": "<p><em>Acampar puede ser simple si alguien te explica lo esencial.</em></p>"
          }
        },
        {
          "type": "paragraph",
          "settings": {
            "text": "<p>Por eso creé esta guía.</p>"
          }
        },
        {
          "type": "paragraph",
          "settings": {
            "text": "<p><strong>Para que puedas salir este mismo fin de semana sin miedo.</strong></p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
