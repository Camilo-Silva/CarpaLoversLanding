<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .clh-section {
    background: #fff;
    padding: 40px 16px 50px;
  }
  .clh-container {
    max-width: 900px;
    margin: 0 auto;
  }
  .clh-heading {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    color: #111;
    margin-bottom: 20px;
  }

  /* === PRIMER PRODUCTO — ancho completo, horizontal === */
  .clh-featured {
    background: #fff;
    border: 1px solid #dde0e7;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,.09);
    display: flex;
    margin-bottom: 16px;
  }
  .clh-featured-img {
    width: 42%;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
    transition: opacity .15s;
  }
  .clh-featured a:hover .clh-featured-img,
  .clh-grid-card a:hover .clh-grid-img { opacity: .88; }
  .clh-featured-body {
    padding: 24px 26px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
  }
  .clh-featured-badge {
    display: inline-block;
    background: #ad6639;
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .7rem;
    padding: 3px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-bottom: 10px;
    width: fit-content;
  }
  .clh-featured-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 1.15rem;
    color: #111;
    margin-bottom: 12px;
    line-height: 1.3;
  }

  /* === RESTO DE PRODUCTOS — 2 columnas === */
  .clh-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .clh-grid-card {
    background: #fff;
    border: 1px solid #dde0e7;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
    display: flex;
    flex-direction: column;
  }
  .clh-grid-img {
    width: 100%;
    display: block;
    aspect-ratio: 1/1;
    object-fit: cover;
    background: #f0ebe6;
  }
  .clh-grid-body {
    padding: 14px 14px 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .clh-grid-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .88rem;
    color: #111;
    margin-bottom: 10px;
    line-height: 1.3;
    flex: 1;
  }

  /* === PRECIOS === */
  .clh-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .clh-price-new {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 1.2rem;
    color: #111;
  }
  .clh-featured .clh-price-new {
    font-size: 1.6rem;
    color: #ad6639;
  }
  .clh-price-old {
    font-size: .82rem;
    color: #aaa;
    text-decoration: line-through;
    font-family: 'Open Sans', sans-serif;
  }
  .clh-off-badge {
    background: rgba(173,102,57,.12);
    color: #7a4520;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .68rem;
    padding: 2px 7px;
    border-radius: 5px;
    text-transform: uppercase;
  }

  /* === BOTÓN COMPRAR AHORA === */
  .clh-buy-btn {
    display: block;
    background: linear-gradient(180deg, #27ae60, #1e9e4f);
    color: #fff;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .85rem;
    padding: 12px;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 4px 0 #155a2a;
    transition: all .15s ease;
    margin-top: auto;
  }
  .clh-buy-btn:hover { transform: translateY(2px); box-shadow: 0 2px 0 #155a2a; }
  .clh-featured .clh-buy-btn {
    font-size: 1rem;
    padding: 15px;
    box-shadow: 0 6px 0 #155a2a;
  }

  @media (max-width: 640px) {
    .clh-featured { flex-direction: column; }
    .clh-featured-img { width: 100%; max-height: 260px; }
    .clh-featured-body { padding: 18px 16px 22px; }
    .clh-featured-title { font-size: 1rem; }
  }
</style>

<section class="clh-section">
  <div class="clh-container">

    {% if section.settings.heading != blank %}
      <h2 class="clh-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% assign first_block = section.blocks | first %}

    {% if first_block %}
      <!-- 1er producto: ancho completo, layout horizontal -->
      <div class="clh-featured" {{ first_block.shopify_attributes }}>
        {% if first_block.settings.product_image != blank %}
          <a href="{{ first_block.settings.landing_url }}" {% if first_block.settings.landing_url != blank %}{% else %}style="cursor:default;pointer-events:none;"{% endif %}>
            <img src="{{ first_block.settings.product_image | img_url: 'master' }}" alt="{{ first_block.settings.product_title }}" class="clh-featured-img">
          </a>
        {% endif %}
        <div class="clh-featured-body">
          {% if first_block.settings.badge != blank %}
            <div class="clh-featured-badge">{{ first_block.settings.badge }}</div>
          {% endif %}
          <div class="clh-featured-title">{{ first_block.settings.product_title }}</div>
          <div class="clh-price-row">
            {% if first_block.settings.price_old != blank %}
              <span class="clh-price-old">{{ first_block.settings.price_old }}</span>
            {% endif %}
            <span class="clh-price-new">{{ first_block.settings.price_new }}</span>
            {% if first_block.settings.off_badge != blank %}
              <span class="clh-off-badge">{{ first_block.settings.off_badge }}</span>
            {% endif %}
          </div>
          <a href="{{ first_block.settings.cta_url }}" class="clh-buy-btn">
            <i class="fa-solid fa-bag-shopping"></i> {{ first_block.settings.cta_text }}
          </a>
        </div>
      </div>
    {% endif %}

    <!-- Resto de productos: grilla 2 columnas -->
    {% if section.blocks.size > 1 %}
      <div class="clh-grid">
        {% for block in section.blocks %}
          {% unless forloop.first %}
            <div class="clh-grid-card" {{ block.shopify_attributes }}>
              {% if block.settings.product_image != blank %}
                <a href="{{ block.settings.landing_url }}" {% if block.settings.landing_url != blank %}{% else %}style="cursor:default;pointer-events:none;"{% endif %}>
                  <img src="{{ block.settings.product_image | img_url: 'master' }}" alt="{{ block.settings.product_title }}" class="clh-grid-img">
                </a>
              {% endif %}
              <div class="clh-grid-body">
                <div class="clh-grid-title">{{ block.settings.product_title }}</div>
                <div class="clh-price-row">
                  {% if block.settings.price_old != blank %}
                    <span class="clh-price-old">{{ block.settings.price_old }}</span>
                  {% endif %}
                  <span class="clh-price-new">{{ block.settings.price_new }}</span>
                  {% if block.settings.off_badge != blank %}
                    <span class="clh-off-badge">{{ block.settings.off_badge }}</span>
                  {% endif %}
                </div>
                <a href="{{ block.settings.cta_url }}" class="clh-buy-btn">
                  <i class="fa-solid fa-bag-shopping"></i> {{ block.settings.cta_text }}
                </a>
              </div>
            </div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Productos Destacados Home",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título de sección",
      "default": "Acceder Ahora 👇"
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Producto",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Imagen del producto"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge superior (solo visible en el 1er producto)",
          "default": "PACK COMPLETO"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Nombre del producto",
          "default": "Pack Completo CarpaLovers"
        },
        {
          "type": "text",
          "id": "price_new",
          "label": "Precio oferta",
          "default": "$21.990"
        },
        {
          "type": "text",
          "id": "price_old",
          "label": "Precio tachado",
          "default": "$29.980"
        },
        {
          "type": "text",
          "id": "off_badge",
          "label": "Badge de ahorro",
          "default": "AHORRÁS $7.990"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Texto del botón",
          "default": "COMPRAR AHORA"
        },
        {
          "type": "text",
          "id": "cta_url",
          "label": "URL directa al checkout",
          "info": "Ejemplo: /cart/VARIANT_ID:1 o la URL completa del checkout"
        },
        {
          "type": "text",
          "id": "landing_url",
          "label": "URL de la landing (click en imagen)",
          "info": "Al clickear la imagen redirige a esta URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Productos Destacados Home",
      "blocks": [
        { "type": "product_item" },
        { "type": "product_item" },
        { "type": "product_item" }
      ]
    }
  ]
}
{% endschema %}
