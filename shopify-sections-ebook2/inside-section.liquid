<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl2-inside-section {
    background-color: {{ section.settings.background_color }};
    padding: 70px 20px;
  }

  .cl2-inside-container { max-width: 900px; margin: 0 auto; }

  .cl2-section-label-inside {
    display: inline-block;
    background: rgba(173,102,57,.12);
    color: {{ section.settings.accent_color }};
    font-family: 'Montserrat', sans-serif;
    font-size: .75rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .cl2-inside-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.1rem;
    font-weight: 900;
    text-align: center;
    margin-bottom: 8px;
    color: #2a1a0e;
    line-height: 1.2;
  }

  .cl2-inside-subtitle {
    font-family: 'Open Sans', sans-serif;
    text-align: center;
    color: #666;
    margin-bottom: 44px;
    font-size: .97rem;
  }

  .cl2-inside-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 18px;
    margin-top: 36px;
  }

  .cl2-inside-card {
    background: #fff;
    border-radius: 14px;
    padding: 26px 22px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    position: relative;
    overflow: hidden;
  }

  .cl2-inside-card--highlight {
    border: 2px solid {{ section.settings.accent_color }};
  }

  .cl2-inside-card--cta {
    background: linear-gradient(135deg, #7a4520, #ad6639);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: center;
  }

  .cl2-inside-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.8rem;
    font-weight: 900;
    color: {{ section.settings.accent_color }};
    margin-bottom: 12px;
    line-height: 1;
  }

  .cl2-inside-card--cta .cl2-inside-num { color: rgba(255,255,255,.4); }

  .cl2-inside-card h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: .97rem;
    font-weight: 700;
    color: #2a1a0e;
    margin-bottom: 10px;
    line-height: 1.35;
  }

  .cl2-inside-card--cta h4 { color: #fff; }

  .cl2-inside-card p {
    font-family: 'Open Sans', sans-serif;
    font-size: .88rem;
    color: #555;
  }

  .cl2-inside-card--cta p { color: rgba(255,255,255,.85); }

  .cl2-inside-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: linear-gradient(180deg, #c97a46, #ad6639);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: .92rem;
    font-weight: 900;
    text-decoration: none;
    padding: 16px 20px;
    border-radius: 10px;
    text-transform: uppercase;
    box-shadow: 0 6px 0 rgba(0,0,0,.3);
    transition: all .15s ease;
    margin-top: 18px;
    width: 100%;
    text-align: center;
  }

  .cl2-inside-cta-btn:hover { transform: translateY(2px); opacity: .9; }

  @media (max-width: 768px) { .cl2-inside-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 500px) { .cl2-inside-grid { grid-template-columns: 1fr; } }
</style>

<section class="cl2-inside-section">
  <div class="cl2-inside-container">
    <div style="text-align:center;">
      <div class="cl2-section-label-inside">
        <i class="fa-solid {{ section.settings.label_icon }}"></i> {{ section.settings.label_text }}
      </div>
    </div>
    <h2 class="cl2-inside-title">{{ section.settings.title }}</h2>
    <p class="cl2-inside-subtitle">{{ section.settings.subtitle }}</p>

    <div class="cl2-inside-grid">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          <div class="cl2-inside-card{% if block.settings.highlight %} cl2-inside-card--highlight{% endif %}" {{ block.shopify_attributes }}>
            <div class="cl2-inside-num">{{ block.settings.symbol }}</div>
            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.description }}</p>
          </div>
        {% endif %}
        {% if block.type == 'cta_card' %}
          <div class="cl2-inside-card cl2-inside-card--cta" {{ block.shopify_attributes }}>
            <i class="fa-solid fa-arrow-right" style="font-size:2rem;color:#fff;margin-bottom:14px;display:block;"></i>
            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.description }}</p>
            <a href="{{ block.settings.cta_url }}" class="cl2-inside-cta-btn">{{ block.settings.cta_text }}</a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Adentro — Ebook2",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#d1ccec"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#ad6639"
    },
    {
      "type": "text",
      "id": "label_icon",
      "label": "Ícono etiqueta",
      "default": "fa-fire"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Texto etiqueta",
      "default": "Lo que te vas a llevar"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Esto No Lo Encontrás en Ningún Otro Lado"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Momentos clave que te cambian la cabeza — y que solo están adentro"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Tarjeta de contenido",
      "settings": [
        {
          "type": "text",
          "id": "symbol",
          "label": "Símbolo / número / emoji",
          "default": "?"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "La pregunta que el 90% de los campistas nunca se hace"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Es simple, rápida, y cuando la incorporás no podés creer que nunca la usaste antes."
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Destacar con borde de acento",
          "default": false
        }
      ]
    },
    {
      "type": "cta_card",
      "name": "Tarjeta CTA",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "¿Querés descubrir el resto?"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripción",
          "default": "Todo esto está dentro de la guía completa."
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "URL del botón"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Texto del botón",
          "default": "ACCEDER A LA GUÍA"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Adentro — Ebook Terreno",
      "blocks": [
        { "type": "card", "settings": { "symbol": "?", "title": "La pregunta que el 90% de los campistas nunca se hace", "description": "Es simple, rápida, y cuando la incorporás no podés creer que nunca la usaste antes.", "highlight": true } },
        { "type": "card", "settings": { "symbol": "!", "title": "El tipo de terreno que engaña a todos — incluso a los experimentados", "description": "Parece ideal. Todos lo eligen. Y es justamente donde no tenés que estar.", "highlight": false } },
        { "type": "card", "settings": { "symbol": "↑", "title": "Por qué estar en altura no garantiza nada", "description": "Hay un detalle dentro de las pendientes que casi nadie conoce — y que hace toda la diferencia.", "highlight": false } },
        { "type": "card", "settings": { "symbol": "🔍", "title": "Spots increíbles que casi nadie conoce — y cómo encontrarlos gratis", "description": "Con coordenadas exactas, fotos reales y experiencias de otros viajeros. Sin pagar un peso.", "highlight": false } },
        { "type": "card", "settings": { "symbol": "⚡", "title": "El hack secreto que los campistas avanzados usan en tormentas", "description": "Con materiales de cualquier ferretería. La mayoría nunca lo descubre solo.", "highlight": false } },
        { "type": "cta_card", "settings": { "title": "¿Querés descubrir el resto?", "description": "Todo esto está dentro de la guía completa.", "cta_text": "ACCEDER A LA GUÍA" } }
      ]
    }
  ]
}
{% endschema %}
