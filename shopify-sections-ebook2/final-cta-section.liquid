<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl2-final-cta-section {
    background: linear-gradient(135deg, {{ section.settings.gradient_from }}, {{ section.settings.gradient_to }});
    color: #fff;
    padding: 70px 20px;
    text-align: center;
  }

  .cl2-final-cta-container { max-width: 900px; margin: 0 auto; }

  .cl2-final-cta-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.3rem;
    font-weight: 900;
    margin-bottom: 14px;
    line-height: 1.2;
    color: #fff;
  }

  .cl2-final-cta-section p {
    font-family: 'Open Sans', sans-serif;
    font-size: 1.08rem;
    color: rgba(255,255,255,.85);
    margin-bottom: 28px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .cl2-final-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(180deg, #c97a46, #ad6639);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 900;
    text-decoration: none;
    padding: 22px 36px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: .5px;
    box-shadow: 0 8px 0 rgba(0,0,0,.35), 0 12px 30px rgba(0,0,0,.3);
    transition: all .15s ease;
    max-width: 640px;
    width: 100%;
    margin: 10px auto;
    position: relative;
    overflow: hidden;
  }

  .cl2-final-cta-btn::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
    animation: cl2FinalShimmer 2.5s infinite;
  }

  @keyframes cl2FinalShimmer { 0%{left:-100%} 100%{left:200%} }

  .cl2-final-cta-btn:hover {
    transform: translateY(3px);
    box-shadow: 0 5px 0 rgba(0,0,0,.35), 0 8px 18px rgba(0,0,0,.25);
  }

  .cl2-final-cta-sub {
    font-family: 'Open Sans', sans-serif;
    font-size: .78rem;
    color: rgba(255,255,255,.6);
    margin-top: 8px;
  }

  .cl2-final-cta-domain {
    font-family: 'Open Sans', sans-serif;
    font-size: .8rem;
    color: rgba(255,255,255,.5);
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .cl2-final-cta-section h2 { font-size: 1.7rem; }
    .cl2-final-cta-btn { font-size: 1rem; padding: 18px; }
  }
</style>

<section class="cl2-final-cta-section">
  <div class="cl2-final-cta-container">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body }}</p>

    <div style="text-align:center;">
      <a href="{{ section.settings.cta_url }}" class="cl2-final-cta-btn">
        <i class="fa-solid {{ section.settings.cta_icon }}"></i>
        {{ section.settings.cta_text }}
      </a>
      {% if section.settings.cta_sub != blank %}
        <p class="cl2-final-cta-sub">{{ section.settings.cta_sub }}</p>
      {% endif %}
    </div>

    {% if section.settings.domain != blank %}
      <p class="cl2-final-cta-domain">{{ section.settings.domain }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Final CTA — Ebook2",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "gradient_from",
      "label": "Color gradiente inicio",
      "default": "#7a4520"
    },
    {
      "type": "color",
      "id": "gradient_to",
      "label": "Color gradiente fin",
      "default": "#ad6639"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Acampar bien no es suerte."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Cuerpo del texto",
      "default": "\"No gana el lugar más lindo. Gana el lugar mejor elegido.\" Después de más de 4 años acampando, aprendimos que las buenas experiencias no pasan por casualidad — pasan porque tomaste buenas decisiones antes. El riesgo es cero, la garantía lo cubre todo."
    },
    {
      "type": "text",
      "id": "cta_icon",
      "label": "Ícono del botón",
      "default": "fa-map-location-dot"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "SÍ, QUIERO APRENDER A ELEGIR EL TERRENO PERFECTO"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    },
    {
      "type": "text",
      "id": "cta_sub",
      "label": "Texto bajo el botón",
      "default": "Solo $14.990 ARS · Acceso en segundos · Garantía 7 días sin preguntas"
    },
    {
      "type": "text",
      "id": "domain",
      "label": "Dominio / firma (opcional)",
      "default": "www.sinmiedoacampar.com"
    }
  ],
  "presets": [
    {
      "name": "Final CTA — Ebook Terreno"
    }
  ]
}
{% endschema %}
