<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl2-story-section {
    padding: 70px 20px;
    background-color: {{ section.settings.background_color }};
  }

  .cl2-story-container { max-width: 900px; margin: 0 auto; }

  .cl2-section-label {
    display: inline-block;
    background: rgba(173,102,57,.12);
    color: {{ section.settings.accent_color }};
    font-family: 'Montserrat', sans-serif;
    font-size: .75rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .cl2-story-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.1rem;
    font-weight: 900;
    margin-bottom: 28px;
    color: #2a1a0e;
    line-height: 1.2;
  }

  .cl2-story-content {
    font-size: 1.05rem;
    border-left: 4px solid {{ section.settings.accent_color }};
    padding-left: 22px;
  }

  .cl2-story-content p {
    font-family: 'Open Sans', sans-serif;
    margin-bottom: 18px;
    color: #444;
    line-height: 1.7;
  }

  .cl2-story-highlight {
    background: linear-gradient(135deg, #f5ede4, #eeddd0);
    border: 1px solid #d4a07a;
    border-radius: 10px;
    padding: 18px 24px;
    margin-top: 24px;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #2a1a0e;
  }

  @media (max-width: 768px) {
    .cl2-story-section h2 { font-size: 1.6rem; }
  }
</style>

<section class="cl2-story-section">
  <div class="cl2-story-container">
    <div class="cl2-section-label">
      <i class="fa-solid {{ section.settings.label_icon }}"></i> {{ section.settings.label_text }}
    </div>

    <h2>{{ section.settings.heading }}</h2>

    <div class="cl2-story-content">
      {{ section.settings.story_body }}
    </div>

    {% if section.settings.highlight_text != blank %}
      <div class="cl2-story-highlight">
        <i class="fa-solid {{ section.settings.highlight_icon }}"></i> {{ section.settings.highlight_text }}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Historia / Intro — Ebook2",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#ad6639"
    },
    {
      "type": "text",
      "id": "label_icon",
      "label": "Ícono de la etiqueta",
      "default": "fa-book-open"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Texto de la etiqueta",
      "default": "La historia detrás de esta guía"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "\"En San Luis el río se desbordó… y nosotros no nos mojamos.\""
    },
    {
      "type": "richtext",
      "id": "story_body",
      "label": "Cuerpo de la historia",
      "default": "<p>Hay algo que frena a muchas personas antes de acampar: el miedo a que todo se arruine con la lluvia.</p><p>Y no es un miedo exagerado. A muchos les pasa.</p><p>En San Luis, una vez, el río se desbordó. El agua avanzó… y varias carpas terminaron inundadas.</p><p><strong>Nosotros no.</strong></p><p>No porque elegimos el lugar &ldquo;más lindo&rdquo;. Sino porque elegimos el lugar <em>correcto</em>.</p><p>Ahí entendimos algo clave: acampar bien no es cuestión de suerte… <strong>es estrategia.</strong></p>"
    },
    {
      "type": "text",
      "id": "highlight_icon",
      "label": "Ícono del highlight",
      "default": "fa-lightbulb"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Texto del bloque destacado",
      "default": "Y hoy te la voy a enseñar — paso a paso, con las herramientas exactas que usamos en cada salida."
    }
  ],
  "presets": [
    {
      "name": "Historia / Intro — Ebook Terreno"
    }
  ]
}
{% endschema %}
