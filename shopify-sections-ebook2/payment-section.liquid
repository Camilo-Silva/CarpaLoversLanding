<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl2-payment-section {
    background: {{ section.settings.background_color }};
    padding: 44px 20px;
    text-align: center;
    border-top: 1px solid #e8dbd3;
  }

  .cl2-payment-container { max-width: 900px; margin: 0 auto; }

  .cl2-payment-section h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: .85rem;
    font-weight: 600;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 22px;
  }

  .cl2-pay-img {
    display: block;
    max-width: 420px;
    width: 100%;
    margin: 0 auto 18px;
  }

  .cl2-ssl-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #e8f5e9;
    color: #2e7d32;
    font-family: 'Montserrat', sans-serif;
    font-size: .78rem;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 20px;
    margin-top: 14px;
  }
</style>

<section class="cl2-payment-section">
  <div class="cl2-payment-container">
    <h3>{{ section.settings.heading }}</h3>
    {% if section.settings.payment_image != blank %}
      <img src="{{ section.settings.payment_image | img_url: 'master' }}" alt="{{ section.settings.image_alt }}" class="cl2-pay-img">
    {% endif %}
    <div>
      <span class="cl2-ssl-badge">
        <i class="fa-solid fa-lock"></i> {{ section.settings.ssl_text }}
      </span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Métodos de Pago — Ebook2",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "Métodos de pago"
    },
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Imagen de métodos de pago"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texto alternativo de la imagen",
      "default": "Métodos de pago: Mercado Pago, Visa, Mastercard"
    },
    {
      "type": "text",
      "id": "ssl_text",
      "label": "Texto del badge SSL",
      "default": "Sitio protegido con SSL — Tus datos nunca se comparten con terceros"
    }
  ],
  "presets": [
    {
      "name": "Métodos de Pago — Ebook Terreno"
    }
  ]
}
{% endschema %}
