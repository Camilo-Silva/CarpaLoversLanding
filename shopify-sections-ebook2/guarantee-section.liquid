<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl2-guarantee-section {
    background-color: {{ section.settings.background_color }};
    color: #2a1a0e;
    padding: 70px 20px;
    text-align: center;
  }

  .cl2-guarantee-container { max-width: 900px; margin: 0 auto; }

  .cl2-guarantee-box {
    border: 2px solid #e8dbd3;
    padding: 45px;
    border-radius: 16px;
    background: rgba(255,255,255,.7);
    max-width: 760px;
    margin: 0 auto;
  }

  .cl2-g-icon {
    font-size: 4rem;
    margin-bottom: 18px;
    color: {{ section.settings.accent_color }};
  }

  .cl2-guarantee-box h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.9rem;
    font-weight: 900;
    color: #2a1a0e;
    margin-bottom: 18px;
    line-height: 1.2;
  }

  .cl2-guarantee-box p {
    font-family: 'Open Sans', sans-serif;
    font-size: 1.02rem;
    color: #555;
    margin-bottom: 18px;
    line-height: 1.7;
  }

  .cl2-guarantee-box strong { color: {{ section.settings.accent_color }}; }

  @media (max-width: 768px) {
    .cl2-guarantee-box { padding: 24px 16px; }
    .cl2-guarantee-box h2 { font-size: 1.55rem; }
  }
</style>

<section class="cl2-guarantee-section">
  <div class="cl2-guarantee-container">
    <div class="cl2-guarantee-box">
      <div class="cl2-g-icon"><i class="fa-solid {{ section.settings.icon }}"></i></div>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.body_1 }}</p>
      <p>{{ section.settings.body_2 }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Garantía — Ebook2",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#ad6639"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Ícono Font Awesome",
      "default": "fa-shield-halved"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Garantía \"Cero Riesgo\" — 7 Días"
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Párrafo 1",
      "default": "Probá la guía 7 días. Si sentís que no te aportó lo que esperabas, te devuelvo el 100% de tu dinero sin preguntas — y te quedás con todo el contenido."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Párrafo 2",
      "default": "El riesgo lo asumo yo. Vos solo tenés que aprender a elegir el terreno correcto."
    }
  ],
  "presets": [
    {
      "name": "Garantía — Ebook Terreno"
    }
  ]
}
{% endschema %}
