<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .cl2-ticker-bar {
    background-color: {{ section.settings.background_color }};
    border-top: 2px solid {{ section.settings.accent_color }};
    border-bottom: 2px solid {{ section.settings.accent_color }};
    overflow: hidden;
    display: block;
    padding: 10px 0;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    z-index: 10;
  }

  .cl2-ticker-track {
    display: flex;
    width: max-content;
    animation: cl2TickerScroll {{ section.settings.speed }}s linear infinite;
  }

  .cl2-ticker-bar:hover .cl2-ticker-track {
    animation-play-state: paused;
  }

  .cl2-ticker-group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    width: max-content;
  }

  .cl2-ticker-item {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    padding: 0 48px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    letter-spacing: 0.6px;
    white-space: nowrap;
  }

  .cl2-ticker-icon {
    font-size: .9rem;
    line-height: 1;
    color: {{ section.settings.icon_color }};
    flex-shrink: 0;
    width: 16px;
    text-align: center;
  }

  @keyframes cl2TickerScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media screen and (max-width: 768px) {
    .cl2-ticker-item { font-size: 11px; padding: 0 24px; }
  }
</style>

<div class="cl2-ticker-bar" aria-label="Información de compra" role="marquee">
  <div class="cl2-ticker-track">

    <div class="cl2-ticker-group">
      {% for block in section.blocks %}
        <span class="cl2-ticker-item" {{ block.shopify_attributes }}>
          <i class="cl2-ticker-icon fa-solid {{ block.settings.icon }}"></i>
          {{ block.settings.text }}
        </span>
      {% endfor %}
    </div>

    <div class="cl2-ticker-group" aria-hidden="true">
      {% for block in section.blocks %}
        <span class="cl2-ticker-item">
          <i class="cl2-ticker-icon fa-solid {{ block.settings.icon }}"></i>
          {{ block.settings.text }}
        </span>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Ticker Bar — Ebook2",
  "tag": "div",
  "class": "cl2-ticker-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ad6639"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color bordes superior/inferior",
      "default": "#ad6639"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color de los íconos",
      "default": "#7a4520"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad (segundos por ciclo)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ítem del ticker",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Pago 100% Seguro con Mercado Pago"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono Font Awesome (sin 'fa-solid')",
          "default": "fa-shield-halved",
          "info": "Buscá íconos en fontawesome.com/icons"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ticker Bar — Ebook Terreno",
      "blocks": [
        { "type": "item", "settings": { "text": "Pago 100% Seguro con Mercado Pago", "icon": "fa-shield-halved" } },
        { "type": "item", "settings": { "text": "50% OFF por Tiempo Limitado", "icon": "fa-bolt" } },
        { "type": "item", "settings": { "text": "Acceso Inmediato por Mail", "icon": "fa-envelope" } },
        { "type": "item", "settings": { "text": "Comprá desde toda Latam en tu moneda local", "icon": "fa-globe" } },
        { "type": "item", "settings": { "text": "Pago 100% Seguro: aceptamos tarjetas de todo el mundo", "icon": "fa-lock" } }
      ]
    }
  ]
}
{% endschema %}
