<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&display=swap" rel="stylesheet">

<style>
  @keyframes cl2FloatBounceRight {
    0%, 100% { transform: translateY(0) scale(1); box-shadow: 0 6px 24px rgba(0,0,0,0.35); }
    40%       { transform: translateY(-6px) scale(1.06); box-shadow: 0 14px 32px rgba(0,0,0,0.3); }
    60%       { transform: translateY(-3px) scale(1.03); }
  }

  @keyframes cl2FloatBounceMobile {
    0%, 100% { transform: translateX(-50%) translateY(0) scale(1); box-shadow: 0 6px 24px rgba(0,0,0,0.35); }
    40%       { transform: translateX(-50%) translateY(-6px) scale(1.06); box-shadow: 0 14px 32px rgba(0,0,0,0.3); }
    60%       { transform: translateX(-50%) translateY(-3px) scale(1.03); }
  }

  .cl2-float-cta {
    display: flex;
    position: fixed;
    bottom: 20px;
    right: 28px;
    left: auto;
    transform: none;
    z-index: 9999;
    background: {{ section.settings.button_gradient }};
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 50px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.35);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: .5px;
    align-items: center;
    gap: 10px;
    animation: cl2FloatBounceRight 2.2s ease-in-out infinite;
  }

  .cl2-float-cta:hover {
    animation: none;
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 10px 28px rgba(0,0,0,0.4);
  }

  @media (max-width: 768px) {
    .cl2-float-cta {
      right: auto;
      left: 50%;
      transform: translateX(-50%);
      animation: cl2FloatBounceMobile 2.2s ease-in-out infinite;
    }
    .cl2-float-cta:hover {
      transform: translateX(-50%) translateY(-2px) scale(1.04);
    }
  }
</style>

<a href="{{ section.settings.cta_url }}" class="cl2-float-cta" aria-label="{{ section.settings.cta_text }}">
  <i class="fa-solid {{ section.settings.cta_icon }}"></i>
  {{ section.settings.cta_text }}
</a>

{% schema %}
{
  "name": "Float CTA — Ebook2",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "button_gradient",
      "label": "Gradiente del botón (CSS)",
      "default": "linear-gradient(135deg,#1e9e4f,#27ae60)",
      "info": "Ej: linear-gradient(135deg,#1e9e4f,#27ae60)"
    },
    {
      "type": "text",
      "id": "cta_icon",
      "label": "Ícono Font Awesome",
      "default": "fa-fire"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón flotante",
      "default": "DESCARGAR AHORA"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    }
  ],
  "presets": [
    {
      "name": "Float CTA — Ebook Terreno"
    }
  ]
}
{% endschema %}
