        { "type": "testimonial_row2", "settings": { "quote": "Llevé la guía al celular y la leí en el viaje. Cuando llegamos al camping en Bariloche, fui el único del grupo que evaluó el terreno antes de clavar las estacas. El resto copió mi lógica después de que me vieron analizar tres spots. Una experiencia 10 puntos.", "name": "Ezequiel P.", "city": "Neuquén", "initials": "EP", "avatar_url": "https://randomuser.me/api/portraits/men/41.jpg" } },
