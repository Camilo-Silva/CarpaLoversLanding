  ],
  "presets": [
    {
      "name": "Testimonios — Ebook Terreno",
      "blocks": [
        { "type": "testimonial_row1", "settings": { "quote": "Caímos en una llovizna en Merlo y yo tenía pánico. Apliqué el método de la guía antes de armar: pisé el suelo, busqué la leve pendiente y observé los cauces naturales. Resultado: el agua se fue sola y nosotros dormimos secos. Alucinante.", "name": "Santiago R.", "city": "Córdoba", "initials": "SR", "avatar_bg": "#ad6639", "avatar_url": "https://randomuser.me/api/portraits/men/32.jpg" } },
