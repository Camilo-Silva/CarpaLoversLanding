    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad del carrusel (segundos)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 38
    }
  ],
  "blocks": [
    {
      "type": "testimonial_row1",
      "name": "Testimonio (Fila 1 →)",
