<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl2-tools-section {
    background-color: {{ section.settings.background_color }};
    padding: 70px 20px;
  }

  .cl2-tools-container { max-width: 900px; margin: 0 auto; }

  .cl2-section-label-tools {
    display: inline-block;
    background: rgba(173,102,57,.12);
    color: {{ section.settings.accent_color }};
    font-family: 'Montserrat', sans-serif;
    font-size: .75rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .cl2-tools-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.1rem;
    font-weight: 900;
    text-align: center;
    margin-bottom: 8px;
    color: #2a1a0e;
    line-height: 1.2;
  }

  .cl2-tools-subtitle {
    font-family: 'Open Sans', sans-serif;
    text-align: center;
    color: #666;
    margin-bottom: 44px;
    font-size: .97rem;
  }

  .cl2-tools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 36px;
  }

  .cl2-tool-card {
    background: #fff;
    border-radius: 14px;
    padding: 28px 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    border-top: 4px solid {{ section.settings.accent_color }};
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cl2-tool-icon {
    font-size: 1.8rem;
    color: {{ section.settings.accent_color }};
  }

  .cl2-tool-card h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #2a1a0e;
    line-height: 1.3;
    margin: 0;
  }

  .cl2-tool-card p {
    font-family: 'Open Sans', sans-serif;
    font-size: .9rem;
    color: #555;
    flex: 1;
    line-height: 1.6;
  }

  .cl2-tool-tag {
    display: inline-block;
    background: rgba(45,106,79,.1);
    color: #2d6a4f;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .72rem;
    padding: 4px 12px;
    border-radius: 20px;
    align-self: flex-start;
  }

  .cl2-tools-bottom {
    background: linear-gradient(135deg, #f5ede4, #eeddd0);
    border: 1px solid #d4a07a;
    border-radius: 14px;
    padding: 28px 32px;
    text-align: center;
  }

  .cl2-tools-bottom p {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    color: #2a1a0e;
    font-size: 1rem;
    margin-bottom: 4px;
  }

  .cl2-tools-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(180deg, #c97a46, #ad6639);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 900;
    text-decoration: none;
    padding: 20px 32px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: .5px;
    box-shadow: 0 8px 0 #7a4520, 0 12px 30px rgba(173,102,57,.4);
    transition: all .15s ease;
    max-width: 520px;
    width: 100%;
    margin: 20px auto 0;
    position: relative;
    overflow: hidden;
  }

  .cl2-tools-cta-btn:hover {
    transform: translateY(3px);
    box-shadow: 0 5px 0 #7a4520, 0 8px 18px rgba(173,102,57,.3);
  }

  @media (max-width: 600px) {
    .cl2-tools-grid { grid-template-columns: 1fr; }
    .cl2-tools-title { font-size: 1.75rem; }
  }
</style>

<section class="cl2-tools-section">
  <div class="cl2-tools-container">
    <div style="text-align:center;">
      <div class="cl2-section-label-tools">
        <i class="fa-solid {{ section.settings.label_icon }}"></i> {{ section.settings.label_text }}
      </div>
    </div>
    <h2 class="cl2-tools-title">{{ section.settings.title }}</h2>
    <p class="cl2-tools-subtitle">{{ section.settings.subtitle }}</p>

    <div class="cl2-tools-grid">
      {% for block in section.blocks %}
        <div class="cl2-tool-card" {{ block.shopify_attributes }}>
          <div class="cl2-tool-icon"><i class="fa-solid {{ block.settings.icon }}"></i></div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.description }}</p>
          <span class="cl2-tool-tag">{{ block.settings.tag }}</span>
        </div>
      {% endfor %}
    </div>

    <div class="cl2-tools-bottom">
      <p><i class="fa-solid fa-lock"></i> {{ section.settings.bottom_text }}</p>
      <a href="{{ section.settings.cta_url }}" class="cl2-tools-cta-btn">
        <i class="fa-solid fa-arrow-right"></i> {{ section.settings.cta_text }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Herramientas — Ebook2",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#ad6639"
    },
    {
      "type": "text",
      "id": "label_icon",
      "label": "Ícono de la etiqueta",
      "default": "fa-toolbox"
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Texto de la etiqueta",
      "default": "Lo que los expertos usan"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Tenés las Herramientas. Solo Nadie te Enseñó a Usarlas."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Dentro de la guía descubrís exactamente cómo usar 4 recursos (la mayoría gratuitos) para analizar cualquier terreno antes de llegar — desde tu celular, sin ser experto."
    },
    {
      "type": "textarea",
      "id": "bottom_text",
      "label": "Texto del bloque inferior",
      "default": "Cada una de estas herramientas viene explicada paso a paso dentro de la guía — con capturas, ejemplos reales y qué mirar exactamente."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "QUIERO ACCEDER A TODO ESTO"
    }
  ],
  "blocks": [
    {
      "type": "tool",
      "name": "Herramienta",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono Font Awesome",
          "default": "fa-earth-americas"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Ver el terreno en 3D antes de salir de tu casa"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Existe una herramienta gratuita que te permite literalmente sobrevolar la zona donde vas a acampar."
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Etiqueta",
          "default": "Gratis · En tu celular ahora mismo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Herramientas — Ebook Terreno",
      "blocks": [
        {
          "type": "tool",
          "settings": {
            "icon": "fa-earth-americas",
            "title": "Ver el terreno en 3D antes de salir de tu casa",
            "description": "Existe una herramienta gratuita que te permite sobrevolar la zona donde vas a acampar y detectar depresiones, elevaciones y cursos de agua con solo inclinar la pantalla.",
            "tag": "Gratis · En tu celular ahora mismo"
          }
        },
        {
          "type": "tool",
          "settings": {
            "icon": "fa-mountain",
            "title": "Leer la altura del terreno como un experto",
            "description": "Aprendés a interpretar datos topográficos reales — la habilidad que separa al campista que elige bien del que improvisa y reza para que no llueva.",
            "tag": "Gratis · Funciones básicas"
          }
        },
        {
          "type": "tool",
          "settings": {
            "icon": "fa-users",
            "title": "Validar tu elección con la experiencia real de otros",
            "description": "Descubrís cómo acceder a información de cientos de campistas que ya estuvieron ahí — incluyendo señales de alerta que ningún mapa te va a mostrar.",
            "tag": "Gratis · Datos en tiempo real"
          }
        },
        {
          "type": "tool",
          "settings": {
            "icon": "fa-compass",
            "title": "Entender lo que no ves a simple vista al llegar",
            "description": "Una herramienta que revela exactamente qué elevaciones te rodean — y por qué eso puede ser la diferencia entre dormir seco o amanecer con agua dentro de la carpa.",
            "tag": "Inversión mínima · Vale cada centavo"
          }
        }
      ]
    }
  ]
}
{% endschema %}
