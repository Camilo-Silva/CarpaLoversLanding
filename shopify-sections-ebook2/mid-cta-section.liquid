<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts (omitir si tu tema ya los carga) -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .cl2-mid-cta-section {
    background-color: {{ section.settings.background_color }};
    padding: 32px 20px;
    text-align: center;
    border-top: 3px solid {{ section.settings.border_color }};
    border-bottom: 3px solid {{ section.settings.border_color }};
  }

  .cl2-mid-cta-container { max-width: 900px; margin: 0 auto; }

  .cl2-mid-cta-headline {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: {{ section.settings.text_color }};
    margin-bottom: 6px;
  }

  .cl2-mid-cta-sub {
    font-family: 'Open Sans', sans-serif;
    color: #777;
    margin-bottom: 20px;
    font-size: .95rem;
  }

  .cl2-mid-cta-sub strong { color: {{ section.settings.accent_color }}; }

  .cl2-mid-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(180deg, #c97a46, #ad6639);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 900;
    text-decoration: none;
    padding: 22px 36px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: .5px;
    box-shadow: 0 8px 0 #7a4520, 0 12px 30px rgba(173,102,57,.4);
    transition: all .15s ease;
    max-width: 640px;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .cl2-mid-cta-btn::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.15), transparent);
    animation: cl2MidShimmer 2.5s infinite;
  }

  @keyframes cl2MidShimmer { 0%{left:-100%} 100%{left:200%} }

  .cl2-mid-cta-btn:hover {
    transform: translateY(3px);
    box-shadow: 0 5px 0 #7a4520, 0 8px 18px rgba(173,102,57,.3);
  }

  .cl2-mid-cta-trust {
    font-family: 'Open Sans', sans-serif;
    margin-top: 14px;
    font-size: .8rem;
    color: #aaa;
  }

  @media (max-width: 768px) {
    .cl2-mid-cta-btn { font-size: 1rem; padding: 18px; }
  }
</style>

<section class="cl2-mid-cta-section">
  <div class="cl2-mid-cta-container">
    <p class="cl2-mid-cta-headline">{{ section.settings.headline }}</p>
    <p class="cl2-mid-cta-sub">{{ section.settings.sub_text }} <strong>{{ section.settings.price }}</strong></p>
    <a href="{{ section.settings.cta_url }}" class="cl2-mid-cta-btn">
      <i class="fa-solid {{ section.settings.cta_icon }}"></i>
      {{ section.settings.cta_text }}
    </a>
    <p class="cl2-mid-cta-trust">
      <i class="fa-solid fa-shield-halved"></i> {{ section.settings.trust_text }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Mid CTA — Ebook2",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color del borde",
      "default": "#fed3da"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#3a2a1e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento (precio)",
      "default": "#ad6639"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Título",
      "default": "¿Ya te convenciste?"
    },
    {
      "type": "text",
      "id": "sub_text",
      "label": "Texto bajo el título (antes del precio)",
      "default": "La guía completa de terreno por un único pago de"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Precio destacado",
      "default": "$14.990"
    },
    {
      "type": "text",
      "id": "cta_icon",
      "label": "Ícono del botón",
      "default": "fa-map-location-dot"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "QUIERO MI GUÍA DE TERRENO AHORA"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Texto de confianza bajo el botón",
      "default": "Garantía 7 días sin preguntas · Acceso instantáneo"
    }
  ],
  "presets": [
    {
      "name": "Mid CTA — Ebook Terreno"
    }
  ]
}
{% endschema %}
