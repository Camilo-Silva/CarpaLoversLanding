            "name": "Luciana V.",
            "city": "Corrientes",
            "avatar_url": "https://randomuser.me/api/portraits/women/33.jpg",
            "avatar_color": "#3d9970"
          }
        }
      ]
    }
  ]
}
{% endschema %}
