<!-- Font Awesome (omitir si tu tema ya lo carga) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .clp-ticker-bar {
    background-color: {{ section.settings.background_color }};
    overflow: hidden;
    display: block;
    padding: 10px 0;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    z-index: 10;
  }
  .clp-ticker-track {
    display: flex;
    width: max-content;
    animation: clpTickerScroll {{ section.settings.speed }}s linear infinite;
  }
  .clp-ticker-track:hover { animation-play-state: paused; }
  .clp-ticker-group { display: flex; flex-shrink: 0; align-items: center; width: max-content; }
  .clp-ticker-item {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    padding: 0 48px;
    display: flex;
    align-items: center;
    gap: 9px;
    letter-spacing: 0.6px;
    white-space: nowrap;
    font-family: 'Montserrat', sans-serif;
  }
  .clp-ticker-icon { font-size: 15px; line-height: 1; color: rgba(255,255,255,.6); }
  @keyframes clpTickerScroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media screen and (max-width: 768px) {
    .clp-ticker-item { font-size: 11px; padding: 0 24px; }
  }
</style>

<div class="clp-ticker-bar" aria-label="Información de compra" role="marquee">
  <div class="clp-ticker-track">
    <div class="clp-ticker-group">
      {% for block in section.blocks %}
        <div class="clp-ticker-item" {{ block.shopify_attributes }}>
          <i class="clp-ticker-icon fa-solid {{ block.settings.icon }}"></i> {{ block.settings.text }}
        </div>
      {% endfor %}
    </div>
    <div class="clp-ticker-group" aria-hidden="true">
      {% for block in section.blocks %}
        <div class="clp-ticker-item">
          <i class="clp-ticker-icon fa-solid {{ block.settings.icon }}"></i> {{ block.settings.text }}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ticker Bar Pack",
  "tag": "div",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ad6639"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad (segundos)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icono FA (ej: fa-box-open)",
          "default": "fa-box-open"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Pack Completo — 2 Guías por el Precio de 1.3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ticker Bar Pack",
      "blocks": [
        { "type": "item", "settings": { "icon": "fa-box-open", "text": "Pack Completo — 2 Guías por el Precio de 1.3" } },
        { "type": "item", "settings": { "icon": "fa-shield-halved", "text": "Pago 100% Seguro con Mercado Pago" } },
        { "type": "item", "settings": { "icon": "fa-bolt", "text": "Oferta de Lanzamiento — Precio Especial" } },
        { "type": "item", "settings": { "icon": "fa-envelope", "text": "Acceso Inmediato por Mail" } }
      ]
    }
  ]
}
{% endschema %}
