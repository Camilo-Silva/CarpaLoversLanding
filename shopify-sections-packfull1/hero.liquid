<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

<style>
  .clp-hero {
    background-color: {{ section.settings.background_color }};
    text-align: center;
    padding: 75px 20px 65px;
  }
  .clp-hero .clp-container {
    max-width: 900px;
    margin: 0 auto;
  }
  .clp-pre-headline {
    display: inline-block;
    background: rgba(173,102,57,.12);
    border: 1px solid {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
    font-family: 'Montserrat', sans-serif;
    font-size: .82rem;
    font-weight: 700;
    padding: 6px 18px;
    border-radius: 20px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }
  .clp-hero h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.8rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 20px;
    color: {{ section.settings.text_color }};
  }
  .clp-hero h1 .clp-hl  { color: {{ section.settings.accent_color }}; }
  .clp-hero h1 .clp-red { color: #c0392b; }
  .clp-hero-sub {
    font-family: 'Open Sans', sans-serif;
    font-size: 1.15rem;
    color: #5a3e2e;
    max-width: 680px;
    margin: 0 auto 8px;
    line-height: 1.7;
  }
  .clp-social-proof {
    font-size: .9rem;
    color: #7a5a47;
    margin-bottom: 38px;
    font-family: 'Open Sans', sans-serif;
  }
  .clp-social-proof span { color: {{ section.settings.accent_color }}; font-weight: 700; }
  .clp-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(180deg, #27ae60, #1e9e4f);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 900;
    text-decoration: none;
    padding: 22px 36px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: .5px;
    box-shadow: 0 8px 0 #155a2a, 0 12px 30px rgba(30,158,79,.35);
    transition: all .15s ease;
    max-width: 640px;
    width: 100%;
    margin: 10px auto;
    position: relative;
    overflow: hidden;
  }
  .clp-cta-btn::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);
    animation: clpShimmer 2.5s infinite;
  }
  @keyframes clpShimmer { 0%{left:-100%} 100%{left:200%} }
  .clp-cta-btn:hover { transform: translateY(3px); box-shadow: 0 5px 0 #155a2a, 0 8px 18px rgba(30,158,79,.3); }
  .clp-cta-sub { font-size: .78rem; color: #999; margin-top: 8px; font-family: 'Open Sans', sans-serif; }
  @media (max-width: 768px) {
    .clp-hero h1 { font-size: 2rem; }
    .clp-cta-btn { font-size: 1rem; padding: 18px 18px; }
  }
</style>

<header class="clp-hero">
  <div class="clp-container">
    <p class="clp-pre-headline">
      <i class="fa-solid fa-box-open"></i> {{ section.settings.pre_headline }}
    </p>
    <h1>
      {{ section.settings.h1_line1 }}<br>
      <span class="clp-hl">{{ section.settings.h1_highlight }}</span> {{ section.settings.h1_and }}<br>
      <span class="clp-red">{{ section.settings.h1_red }}</span>
    </h1>
    <p class="clp-hero-sub">{{ section.settings.subtext }}</p>
    <p class="clp-social-proof">{{ section.settings.social_proof_prefix }} <span>{{ section.settings.social_proof_highlight }}</span> {{ section.settings.social_proof_suffix }}</p>
    <div style="text-align:center;">
      <a href="{{ section.settings.cta_url }}" class="clp-cta-btn">
        <i class="fa-solid fa-box-open"></i> {{ section.settings.cta_text }}
      </a>
      <p class="clp-cta-sub">{{ section.settings.cta_sub }}</p>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Hero Pack",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f8f2ed"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#2a1a0e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color acento",
      "default": "#ad6639"
    },
    {
      "type": "text",
      "id": "pre_headline",
      "label": "Pre-headline",
      "default": "La combinación perfecta para el campista completo"
    },
    {
      "type": "text",
      "id": "h1_line1",
      "label": "H1 línea 1",
      "default": "De cero a experto:"
    },
    {
      "type": "text",
      "id": "h1_highlight",
      "label": "H1 texto resaltado (marrón)",
      "default": "aprendé a acampar bien"
    },
    {
      "type": "text",
      "id": "h1_and",
      "label": "H1 palabra conector",
      "default": "y a"
    },
    {
      "type": "text",
      "id": "h1_red",
      "label": "H1 texto rojo",
      "default": "elegir el terreno perfecto"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtexto",
      "default": "Las 2 guías esenciales de CarpaLovers en un solo Pack — todo lo que necesitás para acampar sin errores y sin mojarte nunca más."
    },
    {
      "type": "text",
      "id": "social_proof_prefix",
      "label": "Prueba social — prefijo",
      "default": "Ya confían en nosotros"
    },
    {
      "type": "text",
      "id": "social_proof_highlight",
      "label": "Prueba social — destacado",
      "default": "+2.000 campistas"
    },
    {
      "type": "text",
      "id": "social_proof_suffix",
      "label": "Prueba social — sufijo",
      "default": "en toda América Latina ★★★★★"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón CTA",
      "default": "QUIERO EL PACK COMPLETO"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón CTA"
    },
    {
      "type": "text",
      "id": "cta_sub",
      "label": "Texto bajo el botón",
      "default": "🔒 Compra segura · ⚡ Acceso instantáneo · 🔄 Garantía 7 días sin preguntas"
    }
  ],
  "presets": [
    {
      "name": "Hero Pack"
    }
  ]
}
{% endschema %}
