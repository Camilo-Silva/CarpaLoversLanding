<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .clp-story-section {
    padding: 70px 20px;
    background: #f8f2ed;
  }
  .clp-story-section .clp-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .clp-section-label {
    display: inline-block;
    background: rgba(173,102,57,.12);
    color: #ad6639;
    font-family: 'Montserrat', sans-serif;
    font-size: .75rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }
  .clp-story-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.1rem;
    font-weight: 900;
    margin-bottom: 28px;
    color: #2a1a0e;
    line-height: 1.2;
  }
  .clp-story-content {
    font-size: 1.05rem;
    border-left: 4px solid #ad6639;
    padding-left: 22px;
  }
  .clp-story-content p {
    margin-bottom: 18px;
    color: #444;
    font-family: 'Open Sans', sans-serif;
    line-height: 1.7;
  }
  .clp-story-highlight {
    background: linear-gradient(135deg, #f5ede4, #eeddd0);
    border: 1px solid #d4a07a;
    border-radius: 10px;
    padding: 18px 24px;
    margin-top: 24px;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #2a1a0e;
  }
</style>

<section class="clp-story-section">
  <div class="clp-container">
    <div class="clp-section-label"><i class="fa-solid fa-book-open"></i> {{ section.settings.label }}</div>
    <h2>{{ section.settings.heading }}</h2>
    <div class="clp-story-content">
      <p>{{ section.settings.p1 }}</p>
      <p>{{ section.settings.p2 }}</p>
      <p>{{ section.settings.p3 }}</p>
      <p>{{ section.settings.p4 }}</p>
      <p>{{ section.settings.p5 }}</p>
    </div>
    <div class="clp-story-highlight">
      <i class="fa-solid fa-lightbulb"></i> {{ section.settings.highlight }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story Pack",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "La historia detrás de CarpaLovers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "&ldquo;Aprendimos todo mal. Ahora te lo contamos bien.&rdquo;"
    },
    {
      "type": "textarea",
      "id": "p1",
      "label": "Párrafo 1",
      "default": "Empezamos como todos: sin saber nada, con equipo prestado, eligiendo la carpa en el lugar más lindo del camping sin pensar en nada más."
    },
    {
      "type": "textarea",
      "id": "p2",
      "label": "Párrafo 2",
      "default": "Nos mojamos. Nos perdimos. Olvidamos cosas. Plantamos la carpa en un cauce seco que se convirtió en río en cinco minutos."
    },
    {
      "type": "textarea",
      "id": "p3",
      "label": "Párrafo 3",
      "default": "Con el tiempo — y muchas salidas — aprendimos a leer el terreno, armar el equipo correcto y planificar sin olvidar nada."
    },
    {
      "type": "textarea",
      "id": "p4",
      "label": "Párrafo 4",
      "default": "Creamos dos guías para que no tengas que aprender todo por las malas:"
    },
    {
      "type": "textarea",
      "id": "p5",
      "label": "Párrafo 5",
      "default": "La primera: todo lo que necesitás para acampar por primera vez con seguridad. La segunda: cómo analizar el terreno como un experto y nunca más mojarte."
    },
    {
      "type": "textarea",
      "id": "highlight",
      "label": "Recuadro destacado",
      "default": "Juntas son el sistema completo: sabés ir a acampar y sabés exactamente dónde plantar la carpa."
    }
  ],
  "presets": [
    {
      "name": "Story Pack"
    }
  ]
}
{% endschema %}
