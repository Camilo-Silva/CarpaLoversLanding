<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .clp-guarantee-section {
    background: #f8f2ed;
    color: #2a1a0e;
    padding: 70px 20px;
    text-align: center;
  }
  .clp-guarantee-section .clp-container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .clp-guarantee-box {
    border: 2px solid #e8dbd3;
    padding: 45px;
    border-radius: 16px;
    background: rgba(255,255,255,.7);
    max-width: 760px;
    margin: 0 auto;
  }
  .clp-g-icon { font-size: 4rem; margin-bottom: 18px; color: #ad6639; }
  .clp-guarantee-box h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.9rem;
    font-weight: 900;
    color: #2a1a0e;
    margin-bottom: 18px;
    line-height: 1.2;
  }
  .clp-guarantee-box p {
    font-size: 1.02rem;
    color: #555;
    margin-bottom: 18px;
    font-family: 'Open Sans', sans-serif;
    line-height: 1.7;
  }
  .clp-highlight { color: #ad6639; font-weight: 700; }
  @media (max-width: 768px) {
    .clp-guarantee-box { padding: 24px 16px; }
    .clp-guarantee-box h2 { font-size: 1.4rem; }
  }
</style>

<section class="clp-guarantee-section">
  <div class="clp-container">
    <div class="clp-guarantee-box">
      <div class="clp-g-icon"><i class="fa-solid fa-shield-halved"></i></div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body_1_before }} <strong class="clp-highlight">{{ section.settings.body_1_highlight }}</strong>{{ section.settings.body_1_after }}</p>
      <p>{{ section.settings.body_2 }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee Pack",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "La Garantía «Cero Estrés» — 7 Días"
    },
    {
      "type": "textarea",
      "id": "body_1_before",
      "label": "Párrafo 1 — texto antes del resaltado",
      "default": "Probá el Pack 7 días. Si sentís que no te aportó lo que esperabas,"
    },
    {
      "type": "text",
      "id": "body_1_highlight",
      "label": "Párrafo 1 — frase resaltada (marrón)",
      "default": "te devolvemos el 100% de tus $21.990 sin preguntas"
    },
    {
      "type": "textarea",
      "id": "body_1_after",
      "label": "Párrafo 1 — texto después del resaltado",
      "default": " — y te quedás con todo el material."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Párrafo 2",
      "default": "El riesgo lo asumimos nosotros. Vos solo tenés que animarte a acampar mejor."
    }
  ],
  "presets": [
    {
      "name": "Guarantee Pack"
    }
  ]
}
{% endschema %}
