<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Open+Sans:wght@400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .clp-mid-cta {
    background: #f8f2ed;
    padding: 32px 20px;
    text-align: center;
    border-top: 3px solid #fed3da;
    border-bottom: 3px solid #fed3da;
  }
  .clp-mid-cta .clp-container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .clp-mid-cta-headline {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
    color: #2a1a0e;
    margin-bottom: 6px;
  }
  .clp-mid-cta-sub {
    color: #777;
    margin-bottom: 20px;
    font-size: .95rem;
    font-family: 'Open Sans', sans-serif;
  }
  .clp-mid-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(180deg, #27ae60, #1e9e4f);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 900;
    text-decoration: none;
    padding: 18px 30px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: .5px;
    box-shadow: 0 8px 0 #155a2a;
    transition: all .15s ease;
    max-width: 480px;
    width: 100%;
  }
  .clp-mid-cta-btn:hover { transform: translateY(3px); box-shadow: 0 5px 0 #155a2a; }
  .clp-mid-cta-trust {
    margin-top: 14px;
    font-size: .8rem;
    color: #aaa;
    font-family: 'Open Sans', sans-serif;
  }
</style>

<section class="clp-mid-cta">
  <div class="clp-container">
    <p class="clp-mid-cta-headline">{{ section.settings.headline }}</p>
    <p class="clp-mid-cta-sub">{{ section.settings.subtext }}</p>
    <a href="{{ section.settings.cta_url }}" class="clp-mid-cta-btn">
      <i class="fa-solid fa-box-open"></i> {{ section.settings.cta_text }}
    </a>
    <p class="clp-mid-cta-trust">
      <i class="fa-solid fa-shield-halved"></i> {{ section.settings.trust_text }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Mid CTA Pack",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "¿Ya te convenciste?"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtexto",
      "default": "Las 2 guías esenciales por un único pago de $21.990"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "QUIERO EL PACK COMPLETO AHORA"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Texto de confianza",
      "default": "Garantía 7 días sin preguntas · Acceso instantáneo a las 2 guías"
    }
  ],
  "presets": [
    {
      "name": "Mid CTA Pack"
    }
  ]
}
{% endschema %}
