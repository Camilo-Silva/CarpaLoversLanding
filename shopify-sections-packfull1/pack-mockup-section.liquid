<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Open+Sans:wght@400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .clp-pack-mockup {
    background: #fff;
    padding: 40px 0 0 0;
    text-align: center;
  }
  .clp-pack-mockup h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    color: #2a1a0e;
    margin-bottom: 24px;
    padding: 0 20px;
    line-height: 1.2;
  }
  .clp-pack-mockup h2 i { color: #ad6639; margin-right: 8px; }
  .clp-pack-mockup-img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    padding: 0;
  }
</style>

<section class="clp-pack-mockup">
  <h2><i class="fa-solid fa-box-open"></i> {{ section.settings.heading }}</h2>
  {% if section.settings.image != blank %}
    <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading }}" class="clp-pack-mockup-img">
  {% else %}
    <img src="{{ 'PackCompleto.png' | asset_url }}" alt="{{ section.settings.heading }}" class="clp-pack-mockup-img">
  {% endif %}
</section>

{% schema %}
{
  "name": "Pack Mockup",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Todo lo que recibís hoy:"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del pack"
    }
  ],
  "presets": [
    {
      "name": "Pack Mockup"
    }
  ]
}
{% endschema %}
