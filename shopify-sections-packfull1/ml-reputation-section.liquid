<!-- Google Fonts + Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Open+Sans:wght@400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  .clp-ml-rep-section {
    background: #d1ccec;
    padding: 40px 20px;
    text-align: center;
  }
  .clp-ml-rep-section .clp-container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .clp-ml-rep-img {
    display: block;
    max-width: 380px;
    width: 100%;
    margin: 0 auto 16px;
    border-radius: 12px;
    box-shadow: 0 3px 14px rgba(0,0,0,.1);
  }
  .clp-ml-live {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff3e0;
    border: 1px solid #ff9800;
    color: #e65100;
    padding: 7px 16px;
    border-radius: 20px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: .82rem;
  }
  .clp-ml-live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #f44336;
    animation: clpBlink2 1s infinite;
    flex-shrink: 0;
  }
  @keyframes clpBlink2 { 0%,100%{opacity:1} 50%{opacity:0} }
</style>

<div class="clp-ml-rep-section">
  <div class="clp-container">
    {% if section.settings.ml_image != blank %}
      <img src="{{ section.settings.ml_image | img_url: 'master' }}" alt="{{ section.settings.ml_image_alt }}" class="clp-ml-rep-img">
    {% else %}
      <img src="{{ 'ML.png' | asset_url }}" alt="{{ section.settings.ml_image_alt }}" class="clp-ml-rep-img">
    {% endif %}
    <div class="clp-ml-live">
      <div class="clp-ml-live-dot"></div>
      <span id="pack-live-count">7</span>&nbsp;{{ section.settings.live_text }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ML Reputation Pack",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "ml_image",
      "label": "Imagen reputación ML"
    },
    {
      "type": "text",
      "id": "ml_image_alt",
      "label": "Alt de la imagen",
      "default": "MercadoLíder Platinum - Reputación del vendedor"
    },
    {
      "type": "text",
      "id": "live_text",
      "label": "Texto live counter",
      "default": "personas mirando este pack ahora"
    }
  ],
  "presets": [
    {
      "name": "ML Reputation Pack"
    }
  ]
}
{% endschema %}
